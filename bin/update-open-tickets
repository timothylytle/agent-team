#!/usr/bin/env python3
"""Deterministic Open Tickets updater.

Fetches current open FreshDesk tickets and updates the Open Tickets section
of today's daily log entry. Replaces the LLM-orchestrated open-tickets skill
with a direct Python implementation.

Usage:
    bin/update-open-tickets [--auto-confirm]
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

# --- Paths ---

REPO_ROOT = Path(__file__).resolve().parent.parent
CONFIG_PATH = REPO_ROOT / "config" / "daily_log.json"
STYLE_CONFIG_PATH = REPO_ROOT / "config" / "doc_styles.json"
CACHE_DB_PATH = REPO_ROOT / "db" / "daily_log_cache.db"
CRM_DB_PATH = REPO_ROOT / "db" / "crm.db"
CACHE_SCHEMA_PATH = REPO_ROOT / "db" / "daily_log_cache_schema.sql"
GWS_SAFE = REPO_ROOT / "bin" / "gws-safe"
FRESHDESK_SAFE = REPO_ROOT / "bin" / "freshdesk-safe"
CRM_SAFE = REPO_ROOT / "bin" / "crm-safe"
DAILY_LOG_CACHE = REPO_ROOT / "bin" / "daily-log-cache"

FRESHDESK_TICKET_URL = "https://miarec.freshdesk.com/a/tickets/{}"


def utf16_len(text):
    """Google Docs API uses UTF-16 code unit indices."""
    return len(text.encode('utf-16-le')) // 2


def load_json_file(path):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"ERROR: config file not found: {path}", file=sys.stderr)
        sys.exit(1)


def run_cmd(args, check=True):
    """Run a subprocess and return (stdout, stderr, returncode)."""
    result = subprocess.run(
        [str(a) for a in args],
        capture_output=True,
        text=True,
    )
    if check and result.returncode not in (0, 2):
        print(f"ERROR: command failed with exit code {result.returncode}", file=sys.stderr)
        print(f"  command: {' '.join(str(a) for a in args)}", file=sys.stderr)
        if result.stderr:
            print(f"  stderr: {result.stderr.strip()}", file=sys.stderr)
        if result.stdout:
            print(f"  stdout: {result.stdout.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout, result.stderr, result.returncode


def get_cache_db():
    """Open the daily_log_cache database, creating it from schema if needed."""
    if not CACHE_DB_PATH.is_file():
        if not CACHE_SCHEMA_PATH.is_file():
            print(f"ERROR: cache schema not found: {CACHE_SCHEMA_PATH}", file=sys.stderr)
            sys.exit(1)
        os.makedirs(CACHE_DB_PATH.parent, exist_ok=True)
        conn = sqlite3.connect(str(CACHE_DB_PATH))
        with open(CACHE_SCHEMA_PATH) as f:
            conn.executescript(f.read())
        conn.close()
    conn = sqlite3.connect(str(CACHE_DB_PATH))
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    # Ensure open_tickets_snapshot table exists
    conn.execute("""
        CREATE TABLE IF NOT EXISTS open_tickets_snapshot (
            freshdesk_ticket_id INTEGER PRIMARY KEY,
            subject TEXT,
            requester_id INTEGER,
            requester_name TEXT,
            fetched_at TEXT NOT NULL
        )
    """)
    conn.commit()
    return conn


def get_crm_db():
    """Open the CRM database."""
    if not CRM_DB_PATH.is_file():
        print(f"ERROR: CRM database not found: {CRM_DB_PATH}", file=sys.stderr)
        sys.exit(1)
    conn = sqlite3.connect(str(CRM_DB_PATH))
    conn.row_factory = sqlite3.Row
    return conn


# --- Step 1: Read config ---

def read_configs():
    print("Reading configuration...")
    config = load_json_file(CONFIG_PATH)
    style = load_json_file(STYLE_CONFIG_PATH)
    return config, style


# --- Step 2: Check cache for section boundaries ---

def get_section_boundaries(doc_id, today_str):
    """Query the daily-log-cache for today's open_tickets section boundaries.
    Returns (start_index, end_index) or None if not cached."""
    db = get_cache_db()
    entry = db.execute(
        "SELECT id FROM entries WHERE document_id = ? AND entry_date = ?",
        (doc_id, today_str),
    ).fetchone()
    if not entry:
        db.close()
        return None
    section = db.execute(
        "SELECT start_index, end_index FROM sections "
        "WHERE entry_id = ? AND section_type = 'open_tickets'",
        (entry["id"],),
    ).fetchone()
    db.close()
    if not section:
        return None
    return section["start_index"], section["end_index"]


# --- Step 3: Fetch open tickets from FreshDesk (with caching) ---

def fetch_open_tickets():
    """Fetch open tickets. Uses snapshot cache if less than 5 minutes old."""
    db = get_cache_db()

    # Check if cache is fresh (less than 5 minutes old)
    row = db.execute(
        "SELECT MIN(fetched_at) as oldest FROM open_tickets_snapshot"
    ).fetchone()
    if row and row["oldest"]:
        oldest = datetime.fromisoformat(row["oldest"].replace("Z", "+00:00"))
        age_seconds = (datetime.now(timezone.utc) - oldest).total_seconds()
        if age_seconds < 300:
            print("Using cached ticket data (less than 5 minutes old)")
            cached = db.execute(
                "SELECT freshdesk_ticket_id, subject, requester_id, requester_name "
                "FROM open_tickets_snapshot"
            ).fetchall()
            db.close()
            return [dict(r) for r in cached]

    db.close()

    # Cache is stale or empty -- fetch from FreshDesk
    print("Fetching open tickets from FreshDesk...")
    stdout, stderr, rc = run_cmd([
        FRESHDESK_SAFE, "tickets", "search", "--query", "status:2",
    ])
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print(f"ERROR: failed to parse FreshDesk ticket search output as JSON", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)

    # FreshDesk search returns {"total": N, "results": [...]}
    results = data.get("results", [])
    if not results:
        # Clear snapshot and return empty
        db = get_cache_db()
        db.execute("DELETE FROM open_tickets_snapshot")
        db.commit()
        db.close()
        return []

    # Resolve requester names
    tickets = []
    requester_names = {}
    for ticket in results:
        tid = ticket["id"]
        subject = ticket["subject"]
        requester_id = ticket.get("requester_id")
        tickets.append({
            "freshdesk_ticket_id": tid,
            "subject": subject,
            "requester_id": requester_id,
        })
        if requester_id and requester_id not in requester_names:
            requester_names[requester_id] = None  # placeholder

    # Resolve names: CRM first, then FreshDesk API for unknowns
    resolve_requester_names(requester_names)

    # Attach names to tickets
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    result_tickets = []
    for t in tickets:
        name = requester_names.get(t["requester_id"], "Unknown") or "Unknown"
        t["requester_name"] = name
        t["fetched_at"] = now_iso
        result_tickets.append(t)

    # Update snapshot cache
    db = get_cache_db()
    db.execute("DELETE FROM open_tickets_snapshot")
    for t in result_tickets:
        db.execute(
            "INSERT INTO open_tickets_snapshot "
            "(freshdesk_ticket_id, subject, requester_id, requester_name, fetched_at) "
            "VALUES (?, ?, ?, ?, ?)",
            (t["freshdesk_ticket_id"], t["subject"],
             t["requester_id"], t["requester_name"], t["fetched_at"]),
        )
    db.commit()
    db.close()

    return result_tickets


def resolve_requester_names(requester_names):
    """Resolve requester_id -> name. Checks CRM DB first, falls back to FreshDesk API.
    Modifies requester_names dict in place."""
    if not requester_names:
        return

    crm_db = get_crm_db()
    unknown_ids = []

    for rid in requester_names:
        row = crm_db.execute(
            "SELECT name FROM contacts WHERE freshdesk_id = ?", (rid,)
        ).fetchone()
        if row and row["name"]:
            requester_names[rid] = row["name"]
        else:
            unknown_ids.append(rid)
    crm_db.close()

    # Fetch unknown contacts from FreshDesk and create CRM records
    for rid in unknown_ids:
        print(f"  Looking up FreshDesk contact {rid}...")
        stdout, stderr, rc = run_cmd(
            [FRESHDESK_SAFE, "contacts", "view", str(rid)],
            check=False,
        )
        if rc != 0:
            requester_names[rid] = "Unknown"
            continue
        try:
            contact = json.loads(stdout)
        except json.JSONDecodeError:
            print(f"ERROR: failed to parse FreshDesk contact {rid} output as JSON", file=sys.stderr)
            print(f"  raw output: {stdout}", file=sys.stderr)
            sys.exit(1)
        name = contact.get("name", "Unknown") or "Unknown"
        requester_names[rid] = name

        # Create CRM contact record
        if name != "Unknown":
            crm_data = {"name": name, "freshdesk_id": rid}
            if contact.get("email"):
                crm_data["email"] = contact["email"]
            print(f"  Creating CRM contact for {name} (FreshDesk ID: {rid})")
            run_cmd(
                [CRM_SAFE, "contacts", "create", "--json", json.dumps(crm_data)],
                check=False,
            )


# --- Step 4: Fetch doc and extract Open Tickets section ---

def fetch_doc_section(doc_id, section_start, section_end):
    """Fetch the Google Doc and extract text from the Open Tickets section."""
    print("Fetching Google Doc...")
    stdout, stderr, rc = run_cmd([
        GWS_SAFE, "docs", "documents", "get",
        "--params", json.dumps({"documentId": doc_id}),
    ])
    try:
        doc = json.loads(stdout)
    except json.JSONDecodeError:
        print(f"ERROR: failed to parse Google Docs output as JSON", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)
    return doc


def extract_section_text(doc, section_start, section_end):
    """Extract plain text from a section of the doc between start and end indices."""
    text = ""
    body_content = doc.get("body", {}).get("content", [])
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)

        # Skip elements outside our section
        if el_end <= section_start or el_start >= section_end:
            continue

        paragraph = element.get("paragraph", {})
        for pe in paragraph.get("elements", []):
            tr = pe.get("textRun", {})
            content = tr.get("content", "")
            text += content

    return text


def parse_existing_ticket_ids(section_text):
    """Extract ticket IDs from existing Open Tickets section text.
    Looks for [<number>] patterns at the start of lines."""
    return set(int(m) for m in re.findall(r"\[(\d+)\]", section_text))


# --- Step 5: Build batchUpdate ---

def build_batch_update(new_tickets, section_end, style):
    """Build the batchUpdate JSON for inserting new ticket lines.

    Inserts at section_end (the startIndex of the next HEADING_2).
    Each ticket line: [<id>] customer - subject - URL\n
    Then applies checkbox bullets and font styling.
    """
    # Build the text to insert
    lines = []
    for t in new_tickets:
        tid = t["freshdesk_ticket_id"]
        name = t["requester_name"]
        subject = t["subject"]
        url = FRESHDESK_TICKET_URL.format(tid)
        line = f"[{tid}] {name} - {subject} - {url}"
        lines.append(line)

    # Join lines with newlines, each line gets its own newline
    insert_text = "\n".join(lines) + "\n"
    insert_index = section_end

    requests = []

    # 1. Insert text
    requests.append({
        "insertText": {
            "location": {"index": insert_index},
            "text": insert_text,
        }
    })

    # 2. Apply checkbox bullets to the inserted lines
    # After insertion, the text occupies [insert_index, insert_index + len(insert_text))
    text_start = insert_index
    text_end = insert_index + utf16_len(insert_text)

    requests.append({
        "createParagraphBullets": {
            "range": {
                "startIndex": text_start,
                "endIndex": text_end,
            },
            "bulletPreset": style["bulletPresets"]["checkbox"],
        }
    })

    # 3. Apply font styling
    text_style = {
        "weightedFontFamily": {
            "fontFamily": style["fonts"]["body"],
        }
    }
    fields = "weightedFontFamily"

    # Check if bodyText color is set
    if style["colors"].get("bodyText"):
        text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["bodyText"]}
        }
        fields += ",foregroundColor"

    requests.append({
        "updateTextStyle": {
            "range": {
                "startIndex": text_start,
                "endIndex": text_end,
            },
            "textStyle": text_style,
            "fields": fields,
        }
    })

    return {"requests": requests}


# --- Step 6: Execute batchUpdate ---

def execute_batch_update(doc_id, batch_json, auto_confirm):
    """Execute the batchUpdate via gws-safe. Handles dry-run and auto-confirm."""
    json_str = json.dumps(batch_json)
    params_str = json.dumps({"documentId": doc_id})

    cmd = [
        GWS_SAFE, "docs", "documents", "batchUpdate",
        "--json", json_str,
        "--params", params_str,
    ]

    print("Executing batchUpdate (dry-run)...")
    stdout, stderr, rc = run_cmd(cmd, check=False)

    if rc == 2:
        # Dry-run enforced -- parse nonce from stderr
        nonce_match = re.search(r"--confirmed\s+([a-f0-9]+)", stderr)
        if not nonce_match:
            print("ERROR: could not parse nonce from dry-run output", file=sys.stderr)
            print(f"stderr: {stderr}", file=sys.stderr)
            sys.exit(1)

        nonce = nonce_match.group(1)

        if stdout.strip():
            print("Dry-run output:")
            print(stdout.strip())

        if auto_confirm:
            print(f"Auto-confirming with nonce {nonce}...")
            confirm_cmd = cmd + ["--confirmed", nonce]
            stdout2, stderr2, rc2 = run_cmd(confirm_cmd, check=False)
            if rc2 != 0:
                print(f"ERROR: confirmed batchUpdate failed with exit code {rc2}", file=sys.stderr)
                if stderr2:
                    print(f"  stderr: {stderr2.strip()}", file=sys.stderr)
                sys.exit(1)
            print("batchUpdate confirmed and applied successfully.")
            return True
        else:
            print(f"\nDry-run enforced. To confirm, re-run with --auto-confirm or manually run:")
            print(f"  {' '.join(str(a) for a in cmd)} --confirmed {nonce}")
            return False
    elif rc == 0:
        print("batchUpdate applied successfully.")
        return True
    else:
        print(f"ERROR: batchUpdate failed with exit code {rc}", file=sys.stderr)
        if stderr:
            print(f"  stderr: {stderr.strip()}", file=sys.stderr)
        sys.exit(1)


# --- Step 7: Update cache ---

def update_cache(doc_id):
    """Re-read the doc and repopulate the daily-log-cache."""
    print("Updating cache...")

    # Fetch fresh doc
    stdout, stderr, rc = run_cmd([
        GWS_SAFE, "docs", "documents", "get",
        "--params", json.dumps({"documentId": doc_id}),
    ])
    try:
        doc = json.loads(stdout)
    except json.JSONDecodeError:
        print(f"ERROR: failed to parse Google Docs output as JSON during cache update", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)
    revision_id = doc.get("revisionId", "")

    # Parse the full document structure
    entries = parse_doc_entries(doc)

    # Populate cache via the daily-log-cache wrapper
    populate_data = {
        "document_id": doc_id,
        "revision_id": revision_id,
        "entries": entries,
    }

    run_cmd([
        DAILY_LOG_CACHE, "populate",
        "--json", json.dumps(populate_data),
    ])
    print("Cache updated.")


def parse_doc_entries(doc):
    """Parse the Google Doc to extract all entries with their sections and subsections."""
    body_content = doc.get("body", {}).get("content", [])

    # Find all HEADING_1 paragraphs (date entries)
    heading1_paragraphs = []
    for element in body_content:
        paragraph = element.get("paragraph", {})
        style = paragraph.get("paragraphStyle", {})
        if style.get("namedStyleType") == "HEADING_1":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading1_paragraphs.append({
                "text": text,
                "start_index": element.get("startIndex", 0),
            })

    if not heading1_paragraphs:
        return []

    # Determine end indices for each entry
    doc_end = body_content[-1].get("endIndex", 0) if body_content else 0
    entries = []
    for i, h1 in enumerate(heading1_paragraphs):
        end_index = heading1_paragraphs[i + 1]["start_index"] if i + 1 < len(heading1_paragraphs) else doc_end
        entries.append({
            "heading_text": h1["text"],
            "start_index": h1["start_index"],
            "end_index": end_index,
        })

    # Parse each entry for sections and subsections
    result = []
    for entry_info in entries:
        # Try to parse date from heading text
        entry_date = parse_date_from_heading(entry_info["heading_text"])
        if not entry_date:
            continue

        sections = parse_entry_sections(
            body_content, entry_info["start_index"], entry_info["end_index"]
        )

        result.append({
            "entry_date": entry_date,
            "heading_text": entry_info["heading_text"],
            "start_index": entry_info["start_index"],
            "end_index": entry_info["end_index"],
            "sections": sections,
        })

    return result


def parse_date_from_heading(heading_text):
    """Parse a date string like 'Friday Mar 27, 2026' into 'YYYY-MM-DD'.
    strptime with %d handles both zero-padded and non-padded days."""
    for fmt in ["%A %b %d, %Y", "%A %B %d, %Y"]:
        try:
            dt = datetime.strptime(heading_text.strip(), fmt)
            return dt.strftime("%Y-%m-%d")
        except ValueError:
            continue
    return None


SECTION_MAP = {
    "Task List": "task_list",
    "Open Tickets:": "open_tickets",
    "Thoughts / Ideas:": "thoughts_ideas",
    "Notes": "notes",
}


def parse_entry_sections(body_content, entry_start, entry_end):
    """Parse HEADING_2 sections within an entry."""
    heading2_paragraphs = []
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start < entry_start or el_start >= entry_end:
            continue
        paragraph = element.get("paragraph", {})
        style = paragraph.get("paragraphStyle", {})
        if style.get("namedStyleType") == "HEADING_2":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading2_paragraphs.append({
                "text": text,
                "start_index": el_start,
            })

    sections = []
    for i, h2 in enumerate(heading2_paragraphs):
        end = heading2_paragraphs[i + 1]["start_index"] if i + 1 < len(heading2_paragraphs) else entry_end
        section_type = SECTION_MAP.get(h2["text"])
        if not section_type:
            continue

        subsections = []
        if section_type == "notes":
            subsections = parse_subsections(body_content, h2["start_index"], end)

        section = {
            "section_type": section_type,
            "heading_text": h2["text"],
            "start_index": h2["start_index"],
            "end_index": end,
        }
        if subsections:
            section["subsections"] = subsections
        sections.append(section)

    return sections


def parse_subsections(body_content, section_start, section_end):
    """Parse HEADING_3 subsections within a section."""
    heading3_paragraphs = []
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        style = paragraph.get("paragraphStyle", {})
        if style.get("namedStyleType") == "HEADING_3":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading3_paragraphs.append({
                "text": text,
                "start_index": el_start,
            })

    subsections = []
    for i, h3 in enumerate(heading3_paragraphs):
        end = heading3_paragraphs[i + 1]["start_index"] if i + 1 < len(heading3_paragraphs) else section_end
        subsections.append({
            "heading_text": h3["text"],
            "start_index": h3["start_index"],
            "end_index": end,
            "sort_order": i,
        })

    return subsections


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Update Open Tickets section of the daily log")
    parser.add_argument("--auto-confirm", action="store_true", help="Automatically confirm the batchUpdate write")
    args = parser.parse_args()
    auto_confirm = args.auto_confirm

    # Step 1: Read configs
    config, style = read_configs()
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")
    today_heading = datetime.now().strftime("%A %b %-d, %Y")

    print(f"Updating Open Tickets for {today_heading}")
    print(f"Document ID: {doc_id}")

    # Step 2: Check cache for section boundaries
    boundaries = get_section_boundaries(doc_id, today_str)
    if not boundaries:
        print("ERROR: No cached entry for today. Run /daily-log first to create the entry.", file=sys.stderr)
        sys.exit(1)

    section_start, section_end = boundaries
    print(f"Open Tickets section: index {section_start} to {section_end}")

    # Step 3: Fetch open tickets
    tickets = fetch_open_tickets()
    print(f"Found {len(tickets)} open ticket(s) in FreshDesk")

    # Step 4: Fetch doc and extract current section text
    doc = fetch_doc_section(doc_id, section_start, section_end)
    section_text = extract_section_text(doc, section_start, section_end)

    # Step 5: Parse existing ticket IDs and compute diff
    existing_ids = parse_existing_ticket_ids(section_text)
    print(f"Found {len(existing_ids)} existing ticket(s) in doc")

    new_tickets = [t for t in tickets if t["freshdesk_ticket_id"] not in existing_ids]

    if not new_tickets:
        print("Open Tickets is already up to date.")
        sys.exit(0)

    print(f"New tickets to add: {len(new_tickets)}")
    for t in new_tickets:
        print(f"  [{t['freshdesk_ticket_id']}] {t['requester_name']} - {t['subject']}")

    # Step 6: Build and execute batchUpdate
    batch = build_batch_update(new_tickets, section_end, style)
    success = execute_batch_update(doc_id, batch, auto_confirm)

    if not success:
        # Dry-run only, not confirmed
        sys.exit(2)

    # Step 7: Update cache
    update_cache(doc_id)

    print(f"\nDone. Added {len(new_tickets)} new ticket(s) to Open Tickets section.")
    for t in new_tickets:
        print(f"  [{t['freshdesk_ticket_id']}] {t['requester_name']} - {t['subject']}")


if __name__ == "__main__":
    main()
