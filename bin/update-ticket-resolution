#!/usr/bin/env python3
"""Deterministic Ticket Resolution updater.

When a FreshDesk ticket is resolved or closed, updates the support Google Doc
with a Resolution section and records resolution data in the CRM.

Usage:
    bin/update-ticket-resolution --ticket <ID> --summary "<text>" [--auto-confirm] [--dry-run]
"""

import argparse
import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

# Allow imports from bin/lib/
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    CRM_SAFE,
    FRESHDESK_SAFE,
    GWS_SAFE,
    run_cmd,
    utf16_len,
)
from lib.support_utils import (
    auto_confirm_gws,
    build_paragraph_style_request,
    build_text_style_request,
    read_style_config,
)

# --- Constants ---

DOC_URL_RE = re.compile(r"docs\.google\.com/document/d/([a-zA-Z0-9_-]+)")


# --- FreshDesk helpers ---


def fetch_ticket(ticket_id):
    """Fetch a FreshDesk ticket with stats and conversations.

    Returns the parsed ticket dict.
    """
    print(f"Fetching FreshDesk ticket #{ticket_id}...")
    stdout, _, _ = run_cmd(
        [FRESHDESK_SAFE, "tickets", "view", str(ticket_id),
         "--include", "stats,conversations"]
    )
    try:
        return json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse ticket data", file=sys.stderr)
        sys.exit(1)



def find_support_doc_id(conversations):
    """Scan ticket conversations for a support doc URL.

    Returns the Google Doc ID, or None.
    """
    for conv in conversations:
        body = conv.get("body", "") or ""
        body_text = conv.get("body_text", "") or ""
        search_text = body + " " + body_text
        match = DOC_URL_RE.search(search_text)
        if match:
            return match.group(1)
    return None


# --- Google Docs helpers ---


def find_key_facts_end(doc):
    """Find the insertion index after Key Facts content.

    Walks the document body to find the HEADING_2 "Key Facts", then
    returns the endIndex of the last paragraph before the next heading
    or end of document.
    """
    body = doc.get("body", {})
    content = body.get("content", [])

    found_key_facts = False
    last_content_end = None

    for element in content:
        paragraph = element.get("paragraph")
        if not paragraph:
            continue

        style = paragraph.get("paragraphStyle", {})
        named_style = style.get("namedStyleType", "")

        # Get the text of this paragraph
        text = ""
        for elem in paragraph.get("elements", []):
            text += elem.get("textRun", {}).get("content", "")
        text = text.strip()

        if found_key_facts:
            # If we hit another heading, stop
            if named_style in ("HEADING_1", "HEADING_2", "HEADING_3"):
                break
            # Track the end of content paragraphs
            end_idx = element.get("endIndex")
            if end_idx is not None:
                last_content_end = end_idx
        elif named_style == "HEADING_2" and text == "Key Facts":
            found_key_facts = True
            last_content_end = element.get("endIndex")

    return last_content_end


def build_resolution_requests(insert_idx, resolved_date_str, summary, style):
    """Build Google Docs batchUpdate requests for the Resolution section.

    Inserts text at insert_idx and applies heading/body formatting.
    Returns list of request dicts.
    """
    lines = [
        "Resolution",
        f"Resolved: {resolved_date_str}",
        summary,
    ]
    insert_text = "\n".join(lines) + "\n"

    requests = []

    # 1. Insert text
    requests.append({
        "insertText": {
            "location": {"index": insert_idx},
            "text": insert_text,
        }
    })

    # 2. Calculate indices for formatting
    idx = insert_idx
    line_ranges = []
    for line in lines:
        line_len = utf16_len(line)
        line_start = idx
        line_end = idx + line_len
        para_end = line_end + 1  # +1 for \n
        line_ranges.append((line_start, line_end, para_end))
        idx = para_end

    # "Resolution" heading (index 0) - HEADING_2
    h_start, h_end, h_para_end = line_ranges[0]
    requests.append(build_paragraph_style_request(h_start, h_para_end, "HEADING_2"))
    requests.append(build_text_style_request(h_start, h_end, style, is_heading=True))

    # Body text styling for content lines (indices 1, 2)
    for i in [1, 2]:
        ls, le, _ = line_ranges[i]
        requests.append(build_text_style_request(ls, le, style, is_heading=False))

    return requests


# --- CRM helpers ---


def find_crm_ticket(freshdesk_ticket_id):
    """Find the CRM ticket record by FreshDesk ticket ID.

    Returns the CRM ticket dict, or None.
    """
    stdout, _, _ = run_cmd([CRM_SAFE, "tickets", "list"])
    try:
        tickets = json.loads(stdout)
    except json.JSONDecodeError:
        return None

    for t in tickets:
        if t.get("freshdesk_id") == freshdesk_ticket_id:
            return t
    return None


# --- Main ---


def main():
    parser = argparse.ArgumentParser(
        description="Update support doc and CRM when a FreshDesk ticket is resolved"
    )
    parser.add_argument(
        "--ticket", type=int, required=True,
        help="FreshDesk ticket ID to process",
    )
    parser.add_argument(
        "--summary", required=True,
        help="Resolution summary text (2-3 sentences)",
    )
    parser.add_argument(
        "--auto-confirm", action="store_true",
        help="Automatically confirm all write operations",
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Show what would be done without making changes",
    )
    args = parser.parse_args()

    auto_confirm = args.auto_confirm
    dry_run = args.dry_run
    ticket_id = args.ticket
    summary = args.summary

    if dry_run:
        auto_confirm = False

    # Step 1: Fetch ticket with stats and conversations
    ticket = fetch_ticket(ticket_id)

    status = ticket.get("status")
    if status not in (4, 5):
        status_names = {2: "Open", 3: "Pending", 4: "Resolved", 5: "Closed",
                        6: "Custom 1", 7: "Custom 2", 9: "Scheduled"}
        name = status_names.get(status, f"Unknown ({status})")
        print(f"ERROR: Ticket #{ticket_id} is not resolved or closed (status: {name})",
              file=sys.stderr)
        sys.exit(1)

    # Step 2: Extract resolution data from stats
    stats = ticket.get("stats", {})
    resolved_at = stats.get("resolved_at")
    closed_at = stats.get("closed_at")

    if resolved_at:
        resolved_dt = datetime.fromisoformat(resolved_at.replace("Z", "+00:00"))
        resolved_date_str = resolved_dt.strftime("%B %-d, %Y")
    elif closed_at:
        resolved_dt = datetime.fromisoformat(closed_at.replace("Z", "+00:00"))
        resolved_date_str = resolved_dt.strftime("%B %-d, %Y")
    else:
        resolved_date_str = datetime.now(timezone.utc).strftime("%B %-d, %Y")

    print(f"  Status: {'Resolved' if status == 4 else 'Closed'}")
    print(f"  Resolved at: {resolved_at or closed_at or 'N/A'}")

    # Step 3: Find support doc
    conversations = ticket.get("conversations", [])
    doc_id = find_support_doc_id(conversations)

    doc_updated = False
    doc_skipped = False
    if not doc_id:
        doc_skipped = True
        print("  WARNING: No support doc found in ticket notes, skipping doc update")
    else:
        print(f"  Support doc: {doc_id}")

        # Step 5: Read the support doc
        print("  Fetching support doc...")
        stdout, _, _ = run_cmd(
            [GWS_SAFE, "docs", "documents", "get",
             "--params", json.dumps({"documentId": doc_id})]
        )
        try:
            doc = json.loads(stdout)
        except json.JSONDecodeError:
            print("ERROR: failed to parse support doc", file=sys.stderr)
            sys.exit(1)

        # Step 6: Find insertion point
        insert_idx = find_key_facts_end(doc)
        # If insertion point is at the document end, back up before the trailing newline
        doc_end = doc.get("body", {}).get("content", [{}])[-1].get("endIndex", 0)
        if insert_idx is not None and insert_idx >= doc_end:
            insert_idx = doc_end - 1
        if insert_idx is None:
            doc_skipped = True
            print("  WARNING: Could not find Key Facts section in doc, skipping doc update")
        else:
            # Check if Resolution heading already exists
            body = doc.get("body", {})
            for element in body.get("content", []):
                paragraph = element.get("paragraph")
                if not paragraph:
                    continue
                style = paragraph.get("paragraphStyle", {})
                if style.get("namedStyleType") == "HEADING_2":
                    text = ""
                    for elem in paragraph.get("elements", []):
                        text += elem.get("textRun", {}).get("content", "")
                    if text.strip() == "Resolution":
                        doc_skipped = True
                        print("  Resolution section already exists in doc, skipping doc update")
                        insert_idx = None
                        break

            if insert_idx is not None:
                print(f"  Inserting Resolution section at index {insert_idx}")

                style = read_style_config()
                requests = build_resolution_requests(
                    insert_idx, resolved_date_str, summary, style
                )

                if dry_run:
                    print("\n  [DRY-RUN] Would insert into support doc:")
                    print(f"    Resolution")
                    print(f"    Resolved: {resolved_date_str}")
                    print(f"    {summary}")
                else:
                    batch = {"requests": requests}
                    cmd_args = [
                        "docs", "documents", "batchUpdate",
                        "--json", json.dumps(batch),
                        "--params", json.dumps({"documentId": doc_id}),
                    ]
                    _, success = auto_confirm_gws(
                        cmd_args, auto_confirm,
                        label=f"Add Resolution section to support doc",
                    )
                    doc_updated = success

    # Step 7: Update CRM ticket record
    crm_ticket = find_crm_ticket(ticket_id)
    crm_updated = False

    if not crm_ticket:
        print(f"  WARNING: No CRM ticket found for FreshDesk #{ticket_id}, skipping CRM update")
    else:
        crm_id = crm_ticket["id"]
        print(f"  CRM ticket ID: {crm_id}")

        update_data = {
            "status": status,
            "resolution_summary": summary,
        }
        if resolved_at:
            update_data["resolved_at"] = resolved_at
        if closed_at:
            update_data["closed_at"] = closed_at

        if dry_run:
            print(f"\n  [DRY-RUN] Would update CRM ticket {crm_id}:")
            for k, v in update_data.items():
                display = v if not isinstance(v, str) or len(v) < 80 else v[:77] + "..."
                print(f"    {k}: {display}")
        else:
            stdout, _, _ = run_cmd(
                [CRM_SAFE, "tickets", "update", str(crm_id),
                 "--json", json.dumps(update_data)]
            )
            try:
                result = json.loads(stdout)
                crm_updated = True
                print(f"  CRM ticket {crm_id} updated")
            except json.JSONDecodeError:
                print(f"  WARNING: CRM update may have failed", file=sys.stderr)

    # Summary
    print("\n" + "=" * 50)
    print("TICKET RESOLUTION SUMMARY")
    print("=" * 50)
    print(f"  Ticket:     #{ticket_id} - {ticket.get('subject', '')}")
    print(f"  Status:     {'Resolved' if status == 4 else 'Closed'}")
    print(f"  Resolved:   {resolved_date_str}")
    if doc_updated:
        doc_status = "done"
    elif doc_skipped:
        doc_status = "skipped"
    elif dry_run:
        doc_status = "dry-run"
    else:
        doc_status = "skipped"
    print(f"  Doc update: {doc_status}")
    print(f"  CRM update: {'done' if crm_updated else 'dry-run' if dry_run and crm_ticket else 'skipped'}")
    print(f"  Summary:    {summary}")
    print()


if __name__ == "__main__":
    main()
