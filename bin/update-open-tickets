#!/usr/bin/env python3
"""Deterministic Open Tickets updater.

Fetches current open FreshDesk tickets and updates the Open Tickets section
of today's daily log entry. Replaces the LLM-orchestrated open-tickets skill
with a direct Python implementation.

Usage:
    bin/update-open-tickets [--auto-confirm]
"""

import argparse
import re
import sys
from datetime import datetime
from pathlib import Path

# Allow imports from bin/lib/
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    FRESHDESK_TICKET_URL,
    execute_batch_update,
    extract_section_text,
    fetch_open_tickets,
    get_cache_db,
    read_configs,
    update_cache,
    utf16_len,
)


# --- Step 2: Check cache for section boundaries ---

def get_section_boundaries(doc_id, today_str):
    """Query the daily-log-cache for today's open_tickets section boundaries.
    Returns (start_index, end_index) or None if not cached."""
    db = get_cache_db()
    entry = db.execute(
        "SELECT id FROM entries WHERE document_id = ? AND entry_date = ?",
        (doc_id, today_str),
    ).fetchone()
    if not entry:
        db.close()
        return None
    section = db.execute(
        "SELECT start_index, end_index FROM sections "
        "WHERE entry_id = ? AND section_type = 'open_tickets'",
        (entry["id"],),
    ).fetchone()
    db.close()
    if not section:
        return None
    return section["start_index"], section["end_index"]


# fetch_open_tickets, fetch_doc (as fetch_doc_section), and extract_section_text
# are imported from lib.daily_log_utils
from lib.daily_log_utils import fetch_doc  # noqa: E402


def parse_existing_ticket_ids(section_text):
    """Extract ticket IDs from existing Open Tickets section text.
    Looks for [<number>] patterns at the start of lines."""
    return set(int(m) for m in re.findall(r"^\[(\d+)\]", section_text, re.MULTILINE))


# --- Step 5: Build batchUpdate ---

def build_batch_update(new_tickets, section_end, style):
    """Build the batchUpdate JSON for inserting new ticket lines.

    Inserts at section_end (the startIndex of the next HEADING_2).
    Each ticket line: [<id>] customer - subject - URL\n
    Then applies checkbox bullets and font styling.
    """
    # Build the text to insert
    lines = []
    for t in new_tickets:
        tid = t["freshdesk_ticket_id"]
        name = t["requester_name"]
        subject = t["subject"]
        url = FRESHDESK_TICKET_URL.format(tid)
        line = f"[{tid}] {name} - {subject} - {url}"
        lines.append(line)

    # Join lines with newlines, each line gets its own newline
    insert_text = "\n".join(lines) + "\n"
    insert_index = section_end

    requests = []

    # 1. Insert text
    requests.append({
        "insertText": {
            "location": {"index": insert_index},
            "text": insert_text,
        }
    })

    # 2. Reset paragraph style to NORMAL_TEXT (prevents inheriting HEADING_2 from section boundary)
    text_start = insert_index
    text_end = insert_index + utf16_len(insert_text)

    requests.append({
        "updateParagraphStyle": {
            "range": {
                "startIndex": text_start,
                "endIndex": text_end,
            },
            "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
            "fields": "namedStyleType",
        }
    })

    # 3. Apply checkbox bullets to the inserted lines
    requests.append({
        "createParagraphBullets": {
            "range": {
                "startIndex": text_start,
                "endIndex": text_end,
            },
            "bulletPreset": style["bulletPresets"]["checkbox"],
        }
    })

    # 3. Apply font styling
    text_style = {
        "weightedFontFamily": {
            "fontFamily": style["fonts"]["body"],
        }
    }
    fields = "weightedFontFamily"

    # Check if bodyText color is set
    if style["colors"].get("bodyText"):
        text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["bodyText"]}
        }
        fields += ",foregroundColor"

    requests.append({
        "updateTextStyle": {
            "range": {
                "startIndex": text_start,
                "endIndex": text_end,
            },
            "textStyle": text_style,
            "fields": fields,
        }
    })

    return {"requests": requests}


# execute_batch_update, update_cache, and doc parsing functions are all
# imported from lib.daily_log_utils


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Update Open Tickets section of the daily log")
    parser.add_argument("--auto-confirm", action="store_true", help="Automatically confirm the batchUpdate write")
    args = parser.parse_args()
    auto_confirm = args.auto_confirm

    # Step 1: Read configs
    config, style = read_configs()
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")
    today_heading = datetime.now().strftime("%A %b %-d, %Y")

    print(f"Updating Open Tickets for {today_heading}")
    print(f"Document ID: {doc_id}")

    # Step 2: Check cache for section boundaries
    boundaries = get_section_boundaries(doc_id, today_str)
    if not boundaries:
        print("ERROR: No cached entry for today. Run /daily-log first to create the entry.", file=sys.stderr)
        sys.exit(1)

    section_start, section_end = boundaries
    print(f"Open Tickets section: index {section_start} to {section_end}")

    # Step 3: Fetch open tickets
    tickets = fetch_open_tickets()
    print(f"Found {len(tickets)} open ticket(s) in FreshDesk")

    # Step 4: Fetch doc and extract current section text
    doc = fetch_doc(doc_id)
    section_text = extract_section_text(doc, section_start, section_end)

    # Step 5: Parse existing ticket IDs and compute diff
    existing_ids = parse_existing_ticket_ids(section_text)
    print(f"Found {len(existing_ids)} existing ticket(s) in doc")

    new_tickets = [t for t in tickets if t["freshdesk_ticket_id"] not in existing_ids]

    if not new_tickets:
        print("Open Tickets is already up to date.")
        sys.exit(0)

    print(f"New tickets to add: {len(new_tickets)}")
    for t in new_tickets:
        print(f"  [{t['freshdesk_ticket_id']}] {t['requester_name']} - {t['subject']}")

    # Step 6: Build and execute batchUpdate
    batch = build_batch_update(new_tickets, section_end, style)
    success = execute_batch_update(doc_id, batch, auto_confirm)

    if not success:
        # Dry-run only, not confirmed
        sys.exit(2)

    # Step 7: Update cache
    update_cache(doc_id)

    print(f"\nDone. Added {len(new_tickets)} new ticket(s) to Open Tickets section.")
    for t in new_tickets:
        print(f"  [{t['freshdesk_ticket_id']}] {t['requester_name']} - {t['subject']}")


if __name__ == "__main__":
    main()
