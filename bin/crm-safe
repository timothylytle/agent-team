# --- Command: files ---

def cmd_files_list(args, cmd_str):
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    if args.company_id is not None:
        rows = db.execute(
            'SELECT df.* FROM drive_files df '
            'JOIN company_files cf ON cf.file_id = df.id '
            'WHERE cf.company_id = ? ORDER BY df.name',
            (args.company_id,),
        ).fetchall()
    else:
        rows = db.execute('SELECT * FROM drive_files ORDER BY name').fetchall()
    output_json(rows_to_list(rows))
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_files_create(args, cmd_str):
    data = _parse_json_arg(args, cmd_str)
    if 'google_file_id' not in data or not data['google_file_id']:
        deny('files create requires "google_file_id" in JSON', cmd_str)
    _write_gate(args, cmd_str, 'Create drive file', data)
    db = get_db()
    cols = []
    vals = []
    allowed = ('google_file_id', 'name', 'mime_type', 'web_view_link')
    for k in allowed:
        if k in data:
            cols.append(k)
            v = data[k]
            if isinstance(v, (dict, list)):
                v = json.dumps(v)
            vals.append(v)
    placeholders = ', '.join('?' for _ in cols)
    col_str = ', '.join(cols)
    try:
        cursor = db.execute(f'INSERT INTO drive_files ({col_str}) VALUES ({placeholders})', vals)
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    row = db.execute('SELECT * FROM drive_files WHERE id = ?', (cursor.lastrowid,)).fetchone()
    output_json(dict(row))
    log_entry(cmd_str, 'CONFIRMED', 0)


def cmd_files_link(args, cmd_str):
    if args.company_id is None or args.file_id is None:
        deny('files link requires --company-id and --file-id', cmd_str)
    data = {'company_id': args.company_id, 'file_id': args.file_id}
    _write_gate(args, cmd_str, f'Link file {args.file_id} to company {args.company_id}', data)
    db = get_db()
    # Verify both exist
    if not db.execute('SELECT id FROM companies WHERE id = ?', (args.company_id,)).fetchone():
        output_json({'error': f'company {args.company_id} not found'})
        sys.exit(1)
    if not db.execute('SELECT id FROM drive_files WHERE id = ?', (args.file_id,)).fetchone():
        output_json({'error': f'file {args.file_id} not found'})
        sys.exit(1)
    try:
        db.execute(
            'INSERT OR IGNORE INTO company_files (company_id, file_id) VALUES (?, ?)',
            (args.company_id, args.file_id),
        )
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    output_json({'linked': True, 'company_id': args.company_id, 'file_id': args.file_id})
    log_entry(cmd_str, 'CONFIRMED', 0)


def cmd_files_unlink(args, cmd_str):
    if args.company_id is None or args.file_id is None:
        deny('files unlink requires --company-id and --file-id', cmd_str)
    data = {'company_id': args.company_id, 'file_id': args.file_id}
    _write_gate(args, cmd_str, f'Unlink file {args.file_id} from company {args.company_id}', data)
    db = get_db()
    try:
        cursor = db.execute(
            'DELETE FROM company_files WHERE company_id = ? AND file_id = ?',
            (args.company_id, args.file_id),
        )
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    output_json({
        'unlinked': cursor.rowcount > 0,
        'company_id': args.company_id,
        'file_id': args.file_id,
    })
    log_entry(cmd_str, 'CONFIRMED', 0)


# --- Helpers ---

def _parse_json_arg(args, cmd_str):
    if not args.json:
        deny('--json is required for this operation', cmd_str)
    try:
        data = json.loads(args.json)
    except json.JSONDecodeError as e:
        deny(f'invalid JSON: {e}', cmd_str)
    if not isinstance(data, dict):
        deny('JSON must be an object', cmd_str)
    return data


def _build_cmd_str(args):
    """Build the canonical command string (without --confirmed) for nonce matching."""
    parts = ['crm']
    parts.append(args.resource)
    parts.append(args.action)
    if getattr(args, 'id', None) is not None:
        parts.append(str(args.id))
    if getattr(args, 'json', None):
        parts.append('--json')
        parts.append(args.json)
    if getattr(args, 'company_id', None) is not None:
        parts.append('--company-id')
        parts.append(str(args.company_id))
    if getattr(args, 'file_id', None) is not None:
        parts.append('--file-id')
        parts.append(str(args.file_id))
    if getattr(args, 'status', None) is not None:
        parts.append('--status')
        parts.append(str(args.status))
    return ' '.join(parts)


def _write_gate(args, cmd_str, operation_desc, preview_data):
    """Enforce dry-run/confirmation for write operations."""
    if args.confirmed:
        ok, err = verify_nonce(args.confirmed, cmd_str)
        if not ok:
            log_entry(cmd_str, f'BLOCKED: {err}')
            output_json({'error': f'BLOCKED: {err}'})
            sys.exit(1)
        log_entry(cmd_str, 'CONFIRMED')
        return  # Proceed with write

    # Dry-run: show what would happen and generate nonce
    nonce = generate_nonce()
    save_nonce(nonce, cmd_str)
    log_entry(cmd_str, 'DRY-RUN-ENFORCED')
    output_json({
        'dry_run': True,
        'operation': operation_desc,
        'data': preview_data,
        'nonce': nonce,
        'message': f'To execute, re-run with --confirmed {nonce}',
    })
    sys.exit(2)


# --- Argument Parsing ---

def build_parser():
    parser = argparse.ArgumentParser(
        prog='crm-safe',
        description='Safe CRM database wrapper',
    )
    parser.add_argument('resource', choices=['companies', 'contacts', 'tickets', 'files'])
    parser.add_argument('action')
    parser.add_argument('id', nargs='?', type=int, default=None)
    parser.add_argument('--json', dest='json', default=None)
    parser.add_argument('--company-id', type=int, default=None)
    parser.add_argument('--file-id', type=int, default=None)
    parser.add_argument('--status', type=int, default=None)
    parser.add_argument('--confirmed', default=None)
    return parser


# --- Routing ---

ROUTES = {
    'companies:list': cmd_companies_list,
    'companies:view': cmd_companies_view,
    'companies:create': cmd_companies_create,
    'companies:update': cmd_companies_update,
    'contacts:list': cmd_contacts_list,
    'contacts:view': cmd_contacts_view,
    'contacts:create': cmd_contacts_create,
    'contacts:update': cmd_contacts_update,
    'tickets:list': cmd_tickets_list,
    'tickets:view': cmd_tickets_view,
    'tickets:create': cmd_tickets_create,
    'tickets:update': cmd_tickets_update,
    'files:list': cmd_files_list,
    'files:create': cmd_files_create,
    'files:link': cmd_files_link,
    'files:unlink': cmd_files_unlink,
}


def main():
    init()

    if len(sys.argv) < 3:
        output_json({'error': 'Usage: crm-safe <resource> <action> [options]'})
        sys.exit(1)

    parser = build_parser()
    args = parser.parse_args()

    cmd_str = _build_cmd_str(args)

    route_key = f'{args.resource}:{args.action}'
    handler = ROUTES.get(route_key)
    if not handler:
        deny(f"command '{args.resource} {args.action}' is not in the allowlist", cmd_str)

    handler(args, cmd_str)


if __name__ == '__main__':
    main()
