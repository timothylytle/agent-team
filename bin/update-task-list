#!/usr/bin/env python3
"""Deterministic Task List updater.

Fetches current calendar events, in-progress tasks, and waiting tasks,
then updates the Task List section and Notes section of today's daily
log entry. Replaces the LLM-orchestrated task-list skill with a direct
Python implementation.

Usage:
    bin/update-task-list [--auto-confirm]
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

# --- Paths ---

REPO_ROOT = Path(__file__).resolve().parent.parent
CONFIG_PATH = REPO_ROOT / "config" / "daily_log.json"
STYLE_CONFIG_PATH = REPO_ROOT / "config" / "doc_styles.json"
CACHE_DB_PATH = REPO_ROOT / "db" / "daily_log_cache.db"
CACHE_SCHEMA_PATH = REPO_ROOT / "db" / "daily_log_cache_schema.sql"
GWS_SAFE = REPO_ROOT / "bin" / "gws-safe"
DAILY_LOG_CACHE = REPO_ROOT / "bin" / "daily-log-cache"

SUPPORT_DOC_RE = re.compile(
    r"Support Doc:\s*(https://docs\.google\.com/document/d/[^\s]+)"
)

CACHE_TTL_SECONDS = 300  # 5 minutes


def utf16_len(text):
    """Google Docs API uses UTF-16 code unit indices."""
    return len(text.encode("utf-16-le")) // 2


def load_json_file(path):
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"ERROR: config file not found: {path}", file=sys.stderr)
        sys.exit(1)


def run_cmd(args, check=True):
    """Run a subprocess and return (stdout, stderr, returncode)."""
    result = subprocess.run(
        [str(a) for a in args],
        capture_output=True,
        text=True,
    )
    if check and result.returncode not in (0, 2):
        print(
            f"ERROR: command failed with exit code {result.returncode}",
            file=sys.stderr,
        )
        print(f"  command: {' '.join(str(a) for a in args)}", file=sys.stderr)
        if result.stderr:
            print(f"  stderr: {result.stderr.strip()}", file=sys.stderr)
        if result.stdout:
            print(f"  stdout: {result.stdout.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout, result.stderr, result.returncode


# --- Database ---


def get_cache_db():
    """Open the daily_log_cache database, creating it from schema if needed."""
    if not CACHE_DB_PATH.is_file():
        if not CACHE_SCHEMA_PATH.is_file():
            print(
                f"ERROR: cache schema not found: {CACHE_SCHEMA_PATH}",
                file=sys.stderr,
            )
            sys.exit(1)
        os.makedirs(CACHE_DB_PATH.parent, exist_ok=True)
        conn = sqlite3.connect(str(CACHE_DB_PATH))
        with open(CACHE_SCHEMA_PATH) as f:
            conn.executescript(f.read())
        conn.close()
    conn = sqlite3.connect(str(CACHE_DB_PATH))
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    # Ensure cache tables exist
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS calendar_events_cache (
            event_id TEXT PRIMARY KEY,
            summary TEXT,
            start_time TEXT,
            end_time TEXT,
            all_day INTEGER,
            color_id TEXT,
            event_type TEXT,
            description TEXT,
            html_link TEXT,
            support_doc_url TEXT,
            fetched_at TEXT NOT NULL
        )
    """
    )
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS tasks_cache (
            task_id TEXT PRIMARY KEY,
            title TEXT,
            list_type TEXT CHECK (list_type IN ('in_progress', 'waiting')),
            due TEXT,
            web_view_link TEXT,
            sort_order INTEGER,
            fetched_at TEXT NOT NULL
        )
    """
    )
    conn.commit()
    return conn


# --- Step 1: Read config ---


def read_configs():
    print("Reading configuration...")
    config = load_json_file(CONFIG_PATH)
    style = load_json_file(STYLE_CONFIG_PATH)

    for key in ["documentId", "inProgressTaskListId", "waitingTaskListId"]:
        if key not in config:
            print(f"ERROR: missing required config key '{key}' in {CONFIG_PATH}", file=sys.stderr)
            sys.exit(1)

    for key in ["fonts", "colors", "bulletPresets"]:
        if key not in style:
            print(f"ERROR: missing required config key '{key}' in {STYLE_CONFIG_PATH}", file=sys.stderr)
            sys.exit(1)

    return config, style


# --- Step 2: Check cache for section boundaries ---


def get_section_boundaries(doc_id, today_str):
    """Query the daily-log-cache for today's task_list and notes section boundaries.
    Returns dict with 'task_list' and 'notes' keys, each (start_index, end_index),
    or None if not cached."""
    db = get_cache_db()
    entry = db.execute(
        "SELECT id FROM entries WHERE document_id = ? AND entry_date = ?",
        (doc_id, today_str),
    ).fetchone()
    if not entry:
        db.close()
        return None

    task_list = db.execute(
        "SELECT start_index, end_index FROM sections "
        "WHERE entry_id = ? AND section_type = 'task_list'",
        (entry["id"],),
    ).fetchone()
    notes = db.execute(
        "SELECT start_index, end_index FROM sections "
        "WHERE entry_id = ? AND section_type = 'notes'",
        (entry["id"],),
    ).fetchone()
    db.close()

    if not task_list or not notes:
        return None

    return {
        "task_list": (task_list["start_index"], task_list["end_index"]),
        "notes": (notes["start_index"], notes["end_index"]),
    }


# --- Step 3: Fetch calendar events (with caching) ---


def _is_cache_fresh(db, table):
    """Check if a cache table has data less than CACHE_TTL_SECONDS old."""
    row = db.execute(f"SELECT MIN(fetched_at) as oldest FROM {table}").fetchone()
    if row and row["oldest"]:
        oldest = datetime.fromisoformat(row["oldest"].replace("Z", "+00:00"))
        age = (datetime.now(timezone.utc) - oldest).total_seconds()
        return age < CACHE_TTL_SECONDS
    return False


def fetch_calendar_events(config, today_str, tz_offset):
    """Fetch today's calendar events. Uses cache if fresh."""
    db = get_cache_db()
    if _is_cache_fresh(db, "calendar_events_cache"):
        print("Using cached calendar events (less than 5 minutes old)")
        rows = db.execute(
            "SELECT event_id, summary, start_time, end_time, all_day, "
            "color_id, event_type, description, html_link, support_doc_url "
            "FROM calendar_events_cache"
        ).fetchall()
        db.close()
        return [dict(r) for r in rows]
    db.close()

    print("Fetching calendar events...")
    exclude_colors = set(config.get("excludeEventColorIds", []))
    params = {
        "calendarId": "primary",
        "timeMin": f"{today_str}T00:00:00{tz_offset}",
        "timeMax": f"{today_str}T23:59:59{tz_offset}",
        "singleEvents": True,
        "orderBy": "startTime",
    }
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "calendar", "events", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse calendar events output as JSON", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)

    items = data.get("items", [])
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    events = []
    for item in items:
        # Filter out workingLocation events
        if item.get("eventType") == "workingLocation":
            continue
        # Filter out excluded colorIds
        if item.get("colorId") in exclude_colors:
            continue

        all_day = "date" in item.get("start", {})
        start_time = item["start"].get("date") or item["start"].get("dateTime", "")
        end_time = item["end"].get("date") or item["end"].get("dateTime", "")
        description = item.get("description", "")
        support_doc_match = SUPPORT_DOC_RE.search(description)
        support_doc_url = support_doc_match.group(1) if support_doc_match else None

        events.append(
            {
                "event_id": item["id"],
                "summary": item.get("summary", "(No title)").strip(),
                "start_time": start_time,
                "end_time": end_time,
                "all_day": 1 if all_day else 0,
                "color_id": item.get("colorId"),
                "event_type": item.get("eventType"),
                "description": description,
                "html_link": item.get("htmlLink", ""),
                "support_doc_url": support_doc_url,
                "fetched_at": now_iso,
            }
        )

    # Update cache
    db = get_cache_db()
    db.execute("DELETE FROM calendar_events_cache")
    for e in events:
        db.execute(
            "INSERT INTO calendar_events_cache "
            "(event_id, summary, start_time, end_time, all_day, color_id, "
            "event_type, description, html_link, support_doc_url, fetched_at) "
            "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            (
                e["event_id"],
                e["summary"],
                e["start_time"],
                e["end_time"],
                e["all_day"],
                e["color_id"],
                e["event_type"],
                e["description"],
                e["html_link"],
                e["support_doc_url"],
                e["fetched_at"],
            ),
        )
    db.commit()
    db.close()

    return events


# --- Step 3b: Fetch tasks (with caching) ---


def fetch_tasks(config, today_str):
    """Fetch in-progress and waiting tasks. Uses cache if fresh."""
    db = get_cache_db()
    if _is_cache_fresh(db, "tasks_cache"):
        print("Using cached tasks (less than 5 minutes old)")
        in_progress = db.execute(
            "SELECT task_id, title, web_view_link, sort_order "
            "FROM tasks_cache WHERE list_type = 'in_progress' ORDER BY sort_order"
        ).fetchall()
        waiting = db.execute(
            "SELECT task_id, title, due, web_view_link, sort_order "
            "FROM tasks_cache WHERE list_type = 'waiting' ORDER BY sort_order"
        ).fetchall()
        db.close()
        return [dict(r) for r in in_progress], [dict(r) for r in waiting]
    db.close()

    in_progress_list_id = config["inProgressTaskListId"]
    waiting_list_id = config["waitingTaskListId"]
    today_due = f"{today_str}T00:00:00.000Z"
    now_iso = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    # Fetch in-progress tasks
    print("Fetching in-progress tasks...")
    params = {"tasklist": in_progress_list_id, "showAssigned": True}
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "tasks", "tasks", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print(
            "ERROR: failed to parse in-progress tasks output as JSON", file=sys.stderr
        )
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)

    in_progress = []
    for i, item in enumerate(data.get("items", [])):
        in_progress.append(
            {
                "task_id": item["id"],
                "title": item.get("title", "(No title)").strip(),
                "list_type": "in_progress",
                "due": item.get("due"),
                "web_view_link": item.get("webViewLink", ""),
                "sort_order": i,
                "fetched_at": now_iso,
            }
        )

    # Fetch waiting tasks
    print("Fetching waiting tasks...")
    params = {"tasklist": waiting_list_id, "showAssigned": True}
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "tasks", "tasks", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse waiting tasks output as JSON", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)

    waiting = []
    for i, item in enumerate(data.get("items", [])):
        # Filter to only tasks due today
        if item.get("due") == today_due:
            waiting.append(
                {
                    "task_id": item["id"],
                    "title": item.get("title", "(No title)").strip(),
                    "list_type": "waiting",
                    "due": item.get("due"),
                    "web_view_link": item.get("webViewLink", ""),
                    "sort_order": i,
                    "fetched_at": now_iso,
                }
            )

    # Update cache
    db = get_cache_db()
    db.execute("DELETE FROM tasks_cache")
    for t in in_progress + waiting:
        db.execute(
            "INSERT INTO tasks_cache "
            "(task_id, title, list_type, due, web_view_link, sort_order, fetched_at) "
            "VALUES (?, ?, ?, ?, ?, ?, ?)",
            (
                t["task_id"],
                t["title"],
                t["list_type"],
                t["due"],
                t["web_view_link"],
                t["sort_order"],
                t["fetched_at"],
            ),
        )
    db.commit()
    db.close()

    return in_progress, waiting


# --- Step 4: Fetch doc and parse sections ---


def fetch_doc(doc_id):
    """Fetch the Google Doc."""
    print("Fetching Google Doc...")
    stdout, _, _ = run_cmd(
        [
            GWS_SAFE,
            "docs",
            "documents",
            "get",
            "--params",
            json.dumps({"documentId": doc_id}),
        ]
    )
    try:
        doc = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse Google Docs output as JSON", file=sys.stderr)
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)
    return doc


def extract_section_text(doc, section_start, section_end):
    """Extract plain text from a section of the doc between start and end indices."""
    text = ""
    body_content = doc.get("body", {}).get("content", [])
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_end <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        for pe in paragraph.get("elements", []):
            tr = pe.get("textRun", {})
            content = tr.get("content", "")
            text += content
    return text


def extract_heading3_titles(doc, section_start, section_end):
    """Extract HEADING_3 titles from a section of the doc (live, not cached)."""
    titles = set()
    body_content = doc.get("body", {}).get("content", [])
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start < section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        style = paragraph.get("paragraphStyle", {})
        if style.get("namedStyleType") == "HEADING_3":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            titles.add(text.strip())
    return titles


def find_subsection_boundary(doc, section_start, section_end, label_text):
    """Find the start index of a specific label line within the Task List section.
    Returns (label_start_index, content_start_index, content_end_index) or None.
    label_text should be something like 'Waiting / Blockers:' (with emoji prefix)."""
    body_content = doc.get("body", {}).get("content", [])
    found_label_start = None
    found_content_start = None

    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_end <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        text_stripped = text.strip()

        if found_label_start is not None and found_content_start is None:
            # The line right after the label
            found_content_start = el_start

        if label_text in text_stripped:
            found_label_start = el_start
            found_content_start = None  # reset; content starts on next element

    if found_label_start is None:
        return None

    # Find the end of the content: the next sub-section label or section end
    # Sub-section labels that mark the end of waiting/blockers content
    end_labels = ["\U0001f3b2 Random Fact:"]
    content_end = section_end

    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_start <= (found_content_start or found_label_start) or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        text_stripped = text.strip()
        for end_label in end_labels:
            if end_label in text_stripped:
                content_end = el_start
                break
        if content_end != section_end:
            break

    return (found_label_start, found_content_start or found_label_start, content_end)


def find_priorities_insertion_point(doc, section_start, section_end):
    """Find the index just before the 'Waiting / Blockers' sub-section label.
    This is where new priority items should be inserted."""
    body_content = doc.get("body", {}).get("content", [])
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_end <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        if "\u23f3 Waiting / Blockers:" in text.strip():
            return el_start
    return None


def parse_existing_priorities(section_text):
    """Extract existing priority items from the Task List section text.
    Looks for (event) or (task) patterns."""
    items = set()
    for m in re.finditer(r"\((event|task)\)\s+(.+)", section_text):
        # Normalize: strip the time portion from event lines for matching
        items.add(m.group(0).strip())
    return items


def parse_existing_priority_titles(section_text):
    """Extract just the titles from existing priority items for dedup.
    Returns set of (type, title) tuples."""
    titles = set()
    for m in re.finditer(r"\((event)\)\s+(.+?)(?:\s+\d{1,2}:\d{2}\s+[AP]M|\s+all day)\s*$",
                         section_text, re.MULTILINE):
        titles.add(("event", m.group(2).strip()))
    for m in re.finditer(r"\((task)\)\s+(.+?)$", section_text, re.MULTILINE):
        titles.add(("task", m.group(2).strip()))
    return titles


def parse_existing_waiting_items(doc, section_start, section_end):
    """Extract existing waiting/blocker item titles from the doc.
    Returns the set of titles currently in the waiting/blockers sub-section."""
    boundary = find_subsection_boundary(
        doc, section_start, section_end, "\u23f3 Waiting / Blockers:"
    )
    if not boundary:
        return set()

    _, content_start, content_end = boundary
    text = extract_section_text(doc, content_start, content_end)
    titles = set()
    for line in text.strip().split("\n"):
        line = line.strip()
        if line and line != "None":
            titles.add(line)
    return titles


# --- Step 5: Format time ---


def format_event_time(event):
    """Format an event's time for display. Returns 'all day' or 'h:mm AM/PM'."""
    if event["all_day"]:
        return "all day"
    start = event["start_time"]
    try:
        dt = datetime.fromisoformat(start)
        return dt.strftime("%-I:%M %p")
    except (ValueError, TypeError):
        return ""


# --- Step 6: Sort new entries ---


def sort_new_entries(events, tasks):
    """Sort entries: all-day events (alpha), timed events (by start), tasks (list order).
    Returns a combined list of (type, item) tuples."""
    all_day = [(e, "event") for e in events if e["all_day"]]
    timed = [(e, "event") for e in events if not e["all_day"]]
    task_items = [(t, "task") for t in tasks]

    all_day.sort(key=lambda x: x[0]["summary"].lower())
    timed.sort(key=lambda x: x[0]["start_time"])
    task_items.sort(key=lambda x: x[0]["sort_order"])

    return all_day + timed + task_items


# --- Step 7: Build batchUpdate ---


def build_batch_update(
    new_priority_entries,
    new_waiting_items,
    current_waiting_titles,
    new_notes_entries,
    priorities_insert_index,
    waiting_boundary,
    notes_end_index,
    style,
):
    """Build the batchUpdate JSON.

    This may write to both the Task List section (priorities + waiting/blockers)
    and the Notes section (new HEADING_3 sub-sections).

    CRITICAL: Google Docs batchUpdate processes requests sequentially. When
    inserting text, all indices after the insertion point shift. We must process
    insertions from HIGHEST index to LOWEST index so each insertion doesn't
    invalidate subsequent ones.
    """
    requests = []

    # We'll collect all insertion groups, then sort by index descending.
    # Each group: (insert_index, text, formatting_requests_fn)
    insertion_groups = []

    # --- Notes HEADING_3 sub-sections ---
    if new_notes_entries:
        notes_text = ""
        for item, item_type in new_notes_entries:
            title = item["summary"] if item_type == "event" else item["title"]
            notes_text += f"{title}\n"
            # Link line
            if item_type == "event":
                link_url = item.get("support_doc_url") or item.get("html_link", "")
            else:
                link_url = item.get("web_view_link", "")
            if link_url:
                notes_text += f"{link_url}\n"

        def notes_formatting(base_index, text):
            reqs = []
            offset = 0
            for item, item_type in new_notes_entries:
                title = item["summary"] if item_type == "event" else item["title"]
                heading_start = base_index + offset
                heading_end = heading_start + utf16_len(title + "\n")

                # HEADING_3 paragraph style
                reqs.append(
                    {
                        "updateParagraphStyle": {
                            "range": {
                                "startIndex": heading_start,
                                "endIndex": heading_end,
                            },
                            "paragraphStyle": {"namedStyleType": "HEADING_3"},
                            "fields": "namedStyleType",
                        }
                    }
                )

                # Heading font
                heading_text_style = {
                    "weightedFontFamily": {
                        "fontFamily": style["fonts"]["heading"],
                    }
                }
                heading_fields = "weightedFontFamily"
                if style["colors"].get("headingText"):
                    heading_text_style["foregroundColor"] = {
                        "color": {"rgbColor": style["colors"]["headingText"]}
                    }
                    heading_fields += ",foregroundColor"
                reqs.append(
                    {
                        "updateTextStyle": {
                            "range": {
                                "startIndex": heading_start,
                                "endIndex": heading_end,
                            },
                            "textStyle": heading_text_style,
                            "fields": heading_fields,
                        }
                    }
                )

                offset += utf16_len(title + "\n")

                # Link line
                if item_type == "event":
                    link_url = item.get("support_doc_url") or item.get(
                        "html_link", ""
                    )
                else:
                    link_url = item.get("web_view_link", "")

                if link_url:
                    link_start = base_index + offset
                    link_text_end = link_start + utf16_len(link_url)
                    link_line_end = link_start + utf16_len(link_url + "\n")

                    # Body font on link line
                    body_text_style = {
                        "weightedFontFamily": {
                            "fontFamily": style["fonts"]["body"],
                        }
                    }
                    body_fields = "weightedFontFamily"
                    if style["colors"].get("bodyText"):
                        body_text_style["foregroundColor"] = {
                            "color": {"rgbColor": style["colors"]["bodyText"]}
                        }
                        body_fields += ",foregroundColor"
                    reqs.append(
                        {
                            "updateTextStyle": {
                                "range": {
                                    "startIndex": link_start,
                                    "endIndex": link_line_end,
                                },
                                "textStyle": body_text_style,
                                "fields": body_fields,
                            }
                        }
                    )

                    # Apply link on URL text (excluding trailing newline)
                    reqs.append(
                        {
                            "updateTextStyle": {
                                "range": {
                                    "startIndex": link_start,
                                    "endIndex": link_text_end,
                                },
                                "textStyle": {"link": {"url": link_url}},
                                "fields": "link",
                            }
                        }
                    )

                    offset += utf16_len(link_url + "\n")

            return reqs

        insertion_groups.append((notes_end_index, notes_text, notes_formatting))

    # --- Waiting / Blockers content ---
    # We need to handle the waiting/blockers section. The approach:
    # - If there's existing content between "Waiting / Blockers:" and "Random Fact:",
    #   delete it and re-insert fresh content.
    # - This keeps it idempotent: the waiting/blockers always reflects current state.
    if waiting_boundary:
        _, content_start, content_end = waiting_boundary
        # Build the new waiting content
        all_waiting_titles = set()
        for t in new_waiting_items:
            all_waiting_titles.add(t["title"])
        all_waiting_titles.update(current_waiting_titles)

        if all_waiting_titles:
            waiting_lines = sorted(all_waiting_titles)
        else:
            waiting_lines = ["None"]

        new_waiting_text = "\n".join(waiting_lines) + "\n"

        # We handle waiting/blockers as a delete + insert operation pair.
        # The delete removes current content; the insert adds fresh content.
        # We need a special group for this.
        def waiting_formatting(base_index, text):
            reqs = []
            text_end = base_index + utf16_len(text)

            # Bullet the waiting items (if not "None")
            if waiting_lines != ["None"]:
                reqs.append(
                    {
                        "createParagraphBullets": {
                            "range": {
                                "startIndex": base_index,
                                "endIndex": text_end,
                            },
                            "bulletPreset": style["bulletPresets"]["default"],
                        }
                    }
                )

            # Body font
            body_text_style = {
                "weightedFontFamily": {
                    "fontFamily": style["fonts"]["body"],
                }
            }
            body_fields = "weightedFontFamily"
            if style["colors"].get("bodyText"):
                body_text_style["foregroundColor"] = {
                    "color": {"rgbColor": style["colors"]["bodyText"]}
                }
                body_fields += ",foregroundColor"
            reqs.append(
                {
                    "updateTextStyle": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "textStyle": body_text_style,
                        "fields": body_fields,
                    }
                }
            )
            return reqs

        # Store as a special delete+insert group
        insertion_groups.append(
            (
                content_start,
                new_waiting_text,
                waiting_formatting,
                content_start,
                content_end,
            )
        )

    # --- New priority items ---
    if new_priority_entries:
        priority_text = ""
        for item, item_type in new_priority_entries:
            if item_type == "event":
                time_str = format_event_time(item)
                priority_text += f"(event) {item['summary']} {time_str}\n"
            else:
                priority_text += f"(task) {item['title']}\n"

        def priority_formatting(base_index, text):
            reqs = []
            text_end = base_index + utf16_len(text)

            # Bullet the priority items
            reqs.append(
                {
                    "createParagraphBullets": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "bulletPreset": style["bulletPresets"]["default"],
                    }
                }
            )

            # Body font
            body_text_style = {
                "weightedFontFamily": {
                    "fontFamily": style["fonts"]["body"],
                }
            }
            body_fields = "weightedFontFamily"
            if style["colors"].get("bodyText"):
                body_text_style["foregroundColor"] = {
                    "color": {"rgbColor": style["colors"]["bodyText"]}
                }
                body_fields += ",foregroundColor"
            reqs.append(
                {
                    "updateTextStyle": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "textStyle": body_text_style,
                        "fields": body_fields,
                    }
                }
            )
            return reqs

        insertion_groups.append(
            (priorities_insert_index, priority_text, priority_formatting)
        )

    # --- Build final request list ---
    # Sort groups by insert index descending so higher-index insertions go first.
    # This ensures earlier insertions don't shift later insertion points.
    # Groups with 5 elements are delete+insert pairs; groups with 3 are plain inserts.
    insertion_groups.sort(key=lambda g: g[0], reverse=True)

    for group in insertion_groups:
        if len(group) == 5:
            # Delete+insert pair (waiting/blockers)
            insert_index, text, fmt_fn, del_start, del_end = group
            # Delete existing content first (only if there's content to delete)
            if del_end > del_start:
                requests.append(
                    {
                        "deleteContentRange": {
                            "range": {
                                "startIndex": del_start,
                                "endIndex": del_end,
                            }
                        }
                    }
                )
            # Insert new content at the same position
            requests.append(
                {"insertText": {"location": {"index": del_start}, "text": text}}
            )
            # Formatting
            requests.extend(fmt_fn(del_start, text))
        else:
            insert_index, text, fmt_fn = group
            requests.append(
                {"insertText": {"location": {"index": insert_index}, "text": text}}
            )
            requests.extend(fmt_fn(insert_index, text))

    return {"requests": requests} if requests else None


# --- Step 8: Execute batchUpdate ---


def execute_batch_update(doc_id, batch_json, auto_confirm):
    """Execute the batchUpdate via gws-safe. Handles dry-run and auto-confirm."""
    json_str = json.dumps(batch_json)
    params_str = json.dumps({"documentId": doc_id})

    cmd = [
        GWS_SAFE,
        "docs",
        "documents",
        "batchUpdate",
        "--json",
        json_str,
        "--params",
        params_str,
    ]

    print("Executing batchUpdate (dry-run)...")
    stdout, stderr, rc = run_cmd(cmd, check=False)

    if rc == 2:
        # Dry-run enforced -- parse nonce from stderr
        nonce_match = re.search(r"--confirmed\s+([a-f0-9]+)", stderr)
        if not nonce_match:
            print(
                "ERROR: could not parse nonce from dry-run output", file=sys.stderr
            )
            print(f"stderr: {stderr}", file=sys.stderr)
            sys.exit(1)

        nonce = nonce_match.group(1)

        if stdout.strip():
            print("Dry-run output:")
            print(stdout.strip())

        if auto_confirm:
            print(f"Auto-confirming with nonce {nonce}...")
            confirm_cmd = cmd + ["--confirmed", nonce]
            stdout2, stderr2, rc2 = run_cmd(confirm_cmd, check=False)
            if rc2 != 0:
                print(
                    f"ERROR: confirmed batchUpdate failed with exit code {rc2}",
                    file=sys.stderr,
                )
                if stderr2:
                    print(f"  stderr: {stderr2.strip()}", file=sys.stderr)
                sys.exit(1)
            print("batchUpdate confirmed and applied successfully.")
            return True
        else:
            print(
                f"\nDry-run enforced. To confirm, re-run with --auto-confirm or manually run:"
            )
            print(f"  {' '.join(str(a) for a in cmd)} --confirmed {nonce}")
            return False
    elif rc == 0:
        print("batchUpdate applied successfully.")
        return True
    else:
        print(f"ERROR: batchUpdate failed with exit code {rc}", file=sys.stderr)
        if stderr:
            print(f"  stderr: {stderr.strip()}", file=sys.stderr)
        sys.exit(1)


# --- Step 9: Update cache ---


def update_cache(doc_id):
    """Re-read the doc and repopulate the daily-log-cache."""
    print("Updating cache...")

    stdout, _, _ = run_cmd(
        [
            GWS_SAFE,
            "docs",
            "documents",
            "get",
            "--params",
            json.dumps({"documentId": doc_id}),
        ]
    )
    try:
        doc = json.loads(stdout)
    except json.JSONDecodeError:
        print(
            "ERROR: failed to parse Google Docs output as JSON during cache update",
            file=sys.stderr,
        )
        print(f"  raw output: {stdout}", file=sys.stderr)
        sys.exit(1)
    revision_id = doc.get("revisionId", "")

    entries = parse_doc_entries(doc)

    populate_data = {
        "document_id": doc_id,
        "revision_id": revision_id,
        "entries": entries,
    }

    run_cmd([DAILY_LOG_CACHE, "populate", "--json", json.dumps(populate_data)])
    print("Cache updated.")


def parse_doc_entries(doc):
    """Parse the Google Doc to extract all entries with their sections and subsections."""
    body_content = doc.get("body", {}).get("content", [])

    heading1_paragraphs = []
    for element in body_content:
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") == "HEADING_1":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading1_paragraphs.append(
                {
                    "text": text,
                    "start_index": element.get("startIndex", 0),
                }
            )

    if not heading1_paragraphs:
        return []

    doc_end = body_content[-1].get("endIndex", 0) if body_content else 0
    entries_raw = []
    for i, h1 in enumerate(heading1_paragraphs):
        end_index = (
            heading1_paragraphs[i + 1]["start_index"]
            if i + 1 < len(heading1_paragraphs)
            else doc_end
        )
        entries_raw.append(
            {
                "heading_text": h1["text"],
                "start_index": h1["start_index"],
                "end_index": end_index,
            }
        )

    result = []
    for entry_info in entries_raw:
        entry_date = parse_date_from_heading(entry_info["heading_text"])
        if not entry_date:
            continue
        sections = parse_entry_sections(
            body_content, entry_info["start_index"], entry_info["end_index"]
        )
        result.append(
            {
                "entry_date": entry_date,
                "heading_text": entry_info["heading_text"],
                "start_index": entry_info["start_index"],
                "end_index": entry_info["end_index"],
                "sections": sections,
            }
        )

    return result


def parse_date_from_heading(heading_text):
    """Parse a date string like 'Friday Mar 27, 2026' into 'YYYY-MM-DD'."""
    for fmt in ["%A %b %d, %Y", "%A %B %d, %Y"]:
        try:
            dt = datetime.strptime(heading_text.strip(), fmt)
            return dt.strftime("%Y-%m-%d")
        except ValueError:
            continue
    return None


SECTION_MAP = {
    "Task List": "task_list",
    "Open Tickets:": "open_tickets",
    "Thoughts / Ideas:": "thoughts_ideas",
    "Notes": "notes",
}


def parse_entry_sections(body_content, entry_start, entry_end):
    """Parse HEADING_2 sections within an entry."""
    heading2_paragraphs = []
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start < entry_start or el_start >= entry_end:
            continue
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") == "HEADING_2":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading2_paragraphs.append(
                {
                    "text": text,
                    "start_index": el_start,
                }
            )

    sections = []
    for i, h2 in enumerate(heading2_paragraphs):
        end = (
            heading2_paragraphs[i + 1]["start_index"]
            if i + 1 < len(heading2_paragraphs)
            else entry_end
        )
        section_type = SECTION_MAP.get(h2["text"])
        if not section_type:
            continue

        subsections = []
        if section_type == "notes":
            subsections = parse_subsections(body_content, h2["start_index"], end)

        section = {
            "section_type": section_type,
            "heading_text": h2["text"],
            "start_index": h2["start_index"],
            "end_index": end,
        }
        if subsections:
            section["subsections"] = subsections
        sections.append(section)

    return sections


def parse_subsections(body_content, section_start, section_end):
    """Parse HEADING_3 subsections within a section."""
    heading3_paragraphs = []
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") == "HEADING_3":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            text = text.strip()
            heading3_paragraphs.append(
                {
                    "text": text,
                    "start_index": el_start,
                }
            )

    subsections = []
    for i, h3 in enumerate(heading3_paragraphs):
        end = (
            heading3_paragraphs[i + 1]["start_index"]
            if i + 1 < len(heading3_paragraphs)
            else section_end
        )
        subsections.append(
            {
                "heading_text": h3["text"],
                "start_index": h3["start_index"],
                "end_index": end,
                "sort_order": i,
            }
        )

    return subsections


# --- Main ---


def main():
    parser = argparse.ArgumentParser(
        description="Update Task List section of the daily log"
    )
    parser.add_argument(
        "--auto-confirm",
        action="store_true",
        help="Automatically confirm the batchUpdate write",
    )
    args = parser.parse_args()
    auto_confirm = args.auto_confirm

    # Step 1: Read configs
    config, style = read_configs()
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")
    today_heading = datetime.now().strftime("%A %b %-d, %Y")

    print(f"Updating Task List for {today_heading}")
    print(f"Document ID: {doc_id}")

    # Step 2: Check cache for section boundaries
    boundaries = get_section_boundaries(doc_id, today_str)
    if not boundaries:
        print(
            "ERROR: No cached entry for today. Run /daily-log first to create the entry.",
            file=sys.stderr,
        )
        sys.exit(1)

    tl_start, tl_end = boundaries["task_list"]
    notes_start, notes_end = boundaries["notes"]
    print(f"Task List section: index {tl_start} to {tl_end}")
    print(f"Notes section: index {notes_start} to {notes_end}")

    # Step 3: Get timezone offset and fetch data
    tz_result = subprocess.run(
        ["date", "+%:z"], capture_output=True, text=True
    )
    tz_offset = tz_result.stdout.strip()

    events = fetch_calendar_events(config, today_str, tz_offset)
    in_progress_tasks, waiting_tasks = fetch_tasks(config, today_str)

    print(f"Found {len(events)} calendar event(s)")
    print(f"Found {len(in_progress_tasks)} in-progress task(s)")
    print(f"Found {len(waiting_tasks)} waiting task(s) due today")

    # Step 4: Fetch doc and parse current content
    doc = fetch_doc(doc_id)

    # Parse existing priorities from Task List section
    task_list_text = extract_section_text(doc, tl_start, tl_end)
    existing_priorities = parse_existing_priority_titles(task_list_text)

    # Parse existing HEADING_3 titles from Notes section (live, not cached)
    existing_notes_titles = extract_heading3_titles(doc, notes_start, notes_end)

    # Parse existing waiting items
    current_waiting_titles = parse_existing_waiting_items(doc, tl_start, tl_end)

    print(f"Existing priorities: {len(existing_priorities)}")
    print(f"Existing Notes headings: {len(existing_notes_titles)}")
    print(f"Existing waiting items: {len(current_waiting_titles)}")

    # Step 5: Compute diffs
    # New priority entries: events and tasks not already in the priorities list
    new_priority_events = [
        e
        for e in events
        if ("event", e["summary"]) not in existing_priorities
    ]
    new_priority_tasks = [
        t
        for t in in_progress_tasks
        if ("task", t["title"]) not in existing_priorities
    ]

    # Sort new priority entries
    new_priority_entries = sort_new_entries(new_priority_events, new_priority_tasks)

    # New waiting items: tasks not already in the waiting section
    new_waiting_items = [
        t for t in waiting_tasks if t["title"] not in current_waiting_titles
    ]

    # New Notes HEADING_3 entries: events and tasks not already in Notes
    new_notes_events = [
        e for e in events if e["summary"] not in existing_notes_titles
    ]
    new_notes_tasks = [
        t
        for t in in_progress_tasks
        if t["title"] not in existing_notes_titles
    ]
    new_notes_entries = sort_new_entries(new_notes_events, new_notes_tasks)

    # Determine if waiting/blockers needs updating
    # Rebuild the full set of waiting items from current + new
    all_waiting_set = current_waiting_titles | {t["title"] for t in waiting_tasks}
    waiting_changed = all_waiting_set != current_waiting_titles

    if not new_priority_entries and not new_notes_entries and not waiting_changed:
        print("Task List is already up to date.")
        sys.exit(0)

    # Report what will change
    if new_priority_entries:
        print(f"\nNew priority items to add: {len(new_priority_entries)}")
        for item, item_type in new_priority_entries:
            if item_type == "event":
                print(f"  (event) {item['summary']} {format_event_time(item)}")
            else:
                print(f"  (task) {item['title']}")

    if waiting_changed:
        print(f"\nWaiting/Blockers will be updated")
        for t in new_waiting_items:
            print(f"  + {t['title']}")

    if new_notes_entries:
        print(f"\nNew Notes headings to add: {len(new_notes_entries)}")
        for item, item_type in new_notes_entries:
            title = item["summary"] if item_type == "event" else item["title"]
            print(f"  {title}")

    # Step 6: Find insertion points
    priorities_insert_index = find_priorities_insertion_point(doc, tl_start, tl_end)
    if priorities_insert_index is None and new_priority_entries:
        print(
            "ERROR: could not find 'Waiting / Blockers:' label in Task List section",
            file=sys.stderr,
        )
        sys.exit(1)

    waiting_boundary = None
    if waiting_changed:
        waiting_boundary = find_subsection_boundary(
            doc, tl_start, tl_end, "\u23f3 Waiting / Blockers:"
        )
        if waiting_boundary is None:
            print(
                "ERROR: could not find 'Waiting / Blockers:' sub-section boundaries",
                file=sys.stderr,
            )
            sys.exit(1)

    # Step 7: Build batchUpdate
    batch = build_batch_update(
        new_priority_entries=new_priority_entries if new_priority_entries else [],
        new_waiting_items=waiting_tasks if waiting_changed else [],
        current_waiting_titles=current_waiting_titles if waiting_changed else set(),
        new_notes_entries=new_notes_entries if new_notes_entries else [],
        priorities_insert_index=priorities_insert_index,
        waiting_boundary=waiting_boundary,
        notes_end_index=notes_end,
        style=style,
    )

    if batch is None:
        print("Task List is already up to date.")
        sys.exit(0)

    # Step 8: Execute batchUpdate
    success = execute_batch_update(doc_id, batch, auto_confirm)

    if not success:
        sys.exit(2)

    # Step 9: Update cache
    update_cache(doc_id)

    # Report summary
    summary_parts = []
    if new_priority_entries:
        summary_parts.append(f"{len(new_priority_entries)} priority item(s)")
    if waiting_changed:
        summary_parts.append("waiting/blockers")
    if new_notes_entries:
        summary_parts.append(f"{len(new_notes_entries)} Notes heading(s)")
    print(f"\nDone. Updated: {', '.join(summary_parts)}.")


if __name__ == "__main__":
    main()
