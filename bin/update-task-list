#!/usr/bin/env python3
"""Deterministic Task List updater.

Fetches current calendar events, in-progress tasks, and waiting tasks,
then updates the Task List section of today's daily log entry. Replaces
the LLM-orchestrated task-list skill with a direct Python implementation.

Usage:
    bin/update-task-list [--auto-confirm]
"""

import argparse
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# Allow imports from bin/lib/
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    ensure_cache_fresh,
    execute_batch_update,
    extract_section_text,
    fetch_calendar_events,
    fetch_doc,
    fetch_tasks,
    find_last_bullet_end_in_section,
    format_event_time,
    get_section,
    publish_note,
    read_configs,
    sort_entries,
    update_cache,
    utf16_len,
)


def find_subsection_boundary(doc, section_start, section_end, label_text):
    """Find the start index of a specific label line within the Task List section.
    Returns (label_start_index, content_start_index, content_end_index) or None.
    label_text should be something like 'Waiting / Blockers:' (with emoji prefix)."""
    body_content = doc.get("body", {}).get("content", [])
    found_label_start = None
    found_content_start = None

    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_end <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        text_stripped = text.strip()

        if found_label_start is not None and found_content_start is None:
            # The line right after the label
            found_content_start = el_start

        if label_text in text_stripped:
            found_label_start = el_start
            found_content_start = None  # reset; content starts on next element

    if found_label_start is None:
        return None

    # Waiting/blockers content extends to the section end
    content_end = section_end

    return (found_label_start, found_content_start or found_label_start, content_end)


def find_priorities_insertion_point(doc, section_start, section_end):
    """Find the index just before the 'Waiting / Blockers' sub-section label.
    This is where new priority items should be inserted."""
    body_content = doc.get("body", {}).get("content", [])
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_end <= section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        if "\u23f3 Waiting / Blockers:" in text.strip():
            return el_start
    return None


def parse_existing_priorities(section_text):
    """Extract existing priority items from the Task List section text.
    Looks for (event) or (task) patterns."""
    items = set()
    for m in re.finditer(r"\((event|task)\)\s+(.+)", section_text):
        # Normalize: strip the time portion from event lines for matching
        items.add(m.group(0).strip())
    return items


def parse_existing_priority_titles(section_text):
    """Extract just the titles from existing priority items for dedup.
    Returns set of (type, title) tuples."""
    titles = set()
    for m in re.finditer(r"\((event)\)\s+(.+?)(?:\s+\d{1,2}:\d{2}\s+[AP]M|\s+all day)\s*$",
                         section_text, re.MULTILINE):
        titles.add(("event", m.group(2).strip()))
    for m in re.finditer(r"\((task)\)\s+(.+?)$", section_text, re.MULTILINE):
        titles.add(("task", m.group(2).strip()))
    return titles


def parse_existing_waiting_items(doc, section_start, section_end):
    """Extract existing waiting/blocker item titles from the doc.
    Returns the set of titles currently in the waiting/blockers sub-section."""
    boundary = find_subsection_boundary(
        doc, section_start, section_end, "\u23f3 Waiting / Blockers:"
    )
    if not boundary:
        return set()

    _, content_start, content_end = boundary
    text = extract_section_text(doc, content_start, content_end)
    titles = set()
    for line in text.strip().split("\n"):
        line = line.strip()
        if line and line != "None":
            titles.add(line)
    return titles


# format_event_time and sort_entries are imported from lib.daily_log_utils
# sort_entries replaces the local sort_new_entries (same logic, renamed)
sort_new_entries = sort_entries  # alias for backward compatibility within this file


# --- Step 7: Build batchUpdate ---


def build_batch_update(
    new_priority_entries,
    new_waiting_items,
    current_waiting_titles,
    priorities_insert_index,
    waiting_boundary,
    style,
    inherit_priority_bullet=False,
):
    """Build the batchUpdate JSON.

    This writes to the Task List section (priorities + waiting/blockers).

    When inherit_priority_bullet is True, priority items are inserted before the
    trailing newline of the last existing bullet paragraph. New paragraphs
    inherit bullet membership, paragraph style, and font styling automatically.

    CRITICAL: Google Docs batchUpdate processes requests sequentially. When
    inserting text, all indices after the insertion point shift. We must process
    insertions from HIGHEST index to LOWEST index so each insertion doesn't
    invalidate subsequent ones.
    """
    requests = []

    # We'll collect all insertion groups, then sort by index descending.
    # Each group: (insert_index, text, formatting_requests_fn)
    insertion_groups = []

    # --- Waiting / Blockers content ---
    # We need to handle the waiting/blockers section. The approach:
    # - If there's existing content after "Waiting / Blockers:",
    #   delete it and re-insert fresh content.
    # - This keeps it idempotent: the waiting/blockers always reflects current state.
    if waiting_boundary:
        _, content_start, content_end = waiting_boundary
        # Build the new waiting content
        all_waiting_titles = set()
        for t in new_waiting_items:
            all_waiting_titles.add(t["title"])
        all_waiting_titles.update(current_waiting_titles)

        if all_waiting_titles:
            waiting_lines = sorted(all_waiting_titles)
        else:
            waiting_lines = ["None"]

        new_waiting_text = "\n".join(waiting_lines) + "\n"

        # We handle waiting/blockers as a delete + insert operation pair.
        # The delete removes current content; the insert adds fresh content.
        # We need a special group for this.
        def waiting_formatting(base_index, text):
            reqs = []
            text_end = base_index + utf16_len(text)

            # Reset paragraph style to NORMAL_TEXT
            reqs.append({
                "updateParagraphStyle": {
                    "range": {"startIndex": base_index, "endIndex": text_end},
                    "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
                    "fields": "namedStyleType",
                }
            })

            # Bullet the waiting items (if not "None")
            if waiting_lines != ["None"]:
                reqs.append(
                    {
                        "createParagraphBullets": {
                            "range": {
                                "startIndex": base_index,
                                "endIndex": text_end,
                            },
                            "bulletPreset": style["bulletPresets"]["checkbox"],
                        }
                    }
                )

            # Body font
            body_text_style = {
                "weightedFontFamily": {
                    "fontFamily": style["fonts"]["body"],
                }
            }
            body_fields = "weightedFontFamily"
            if style["colors"].get("bodyText"):
                body_text_style["foregroundColor"] = {
                    "color": {"rgbColor": style["colors"]["bodyText"]}
                }
                body_fields += ",foregroundColor"
            reqs.append(
                {
                    "updateTextStyle": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "textStyle": body_text_style,
                        "fields": body_fields,
                    }
                }
            )
            return reqs

        # Store as a special delete+insert group
        insertion_groups.append(
            (
                content_start,
                new_waiting_text,
                waiting_formatting,
                content_start,
                content_end,
            )
        )

    # --- New priority items ---
    if new_priority_entries:
        priority_lines = []
        for item, item_type in new_priority_entries:
            if item_type == "event":
                time_str = format_event_time(item)
                priority_lines.append(f"(event) {item['summary']} {time_str}")
            else:
                priority_lines.append(f"(task) {item['title']}")

        if inherit_priority_bullet:
            # Inheritance path: leading \n splits existing paragraph, no trailing \n
            priority_text = "\n" + "\n".join(priority_lines)
        else:
            # Fallback path: trailing \n for each line
            priority_text = "\n".join(priority_lines) + "\n"

        def priority_formatting(base_index, text):
            if inherit_priority_bullet:
                # Clear strikethrough that may be inherited from checked checkboxes
                # Skip the leading \n (first code unit) to target only new text
                content_start = base_index + utf16_len("\n")
                text_end = base_index + utf16_len(text)
                return [{
                    "updateTextStyle": {
                        "range": {"startIndex": content_start, "endIndex": text_end},
                        "textStyle": {"strikethrough": False},
                        "fields": "strikethrough",
                    }
                }]

            reqs = []
            text_end = base_index + utf16_len(text)

            # Reset paragraph style to NORMAL_TEXT (prevents inheriting HEADING_2)
            reqs.append({
                "updateParagraphStyle": {
                    "range": {"startIndex": base_index, "endIndex": text_end},
                    "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
                    "fields": "namedStyleType",
                }
            })

            # Bullet the priority items with checkbox preset
            reqs.append(
                {
                    "createParagraphBullets": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "bulletPreset": style["bulletPresets"]["checkbox"],
                    }
                }
            )

            # Body font
            body_text_style = {
                "weightedFontFamily": {
                    "fontFamily": style["fonts"]["body"],
                }
            }
            body_fields = "weightedFontFamily"
            if style["colors"].get("bodyText"):
                body_text_style["foregroundColor"] = {
                    "color": {"rgbColor": style["colors"]["bodyText"]}
                }
                body_fields += ",foregroundColor"
            reqs.append(
                {
                    "updateTextStyle": {
                        "range": {
                            "startIndex": base_index,
                            "endIndex": text_end,
                        },
                        "textStyle": body_text_style,
                        "fields": body_fields,
                    }
                }
            )
            return reqs

        insertion_groups.append(
            (priorities_insert_index, priority_text, priority_formatting)
        )

    # --- Build final request list ---
    # Sort groups by insert index descending so higher-index insertions go first.
    # This ensures earlier insertions don't shift later insertion points.
    # Groups with 5 elements are delete+insert pairs; groups with 3 are plain inserts.
    insertion_groups.sort(key=lambda g: g[0], reverse=True)

    for group in insertion_groups:
        if len(group) == 5:
            # Delete+insert pair (waiting/blockers)
            insert_index, text, fmt_fn, del_start, del_end = group
            # Delete existing content first (only if there's content to delete)
            if del_end > del_start:
                requests.append(
                    {
                        "deleteContentRange": {
                            "range": {
                                "startIndex": del_start,
                                "endIndex": del_end,
                            }
                        }
                    }
                )
            # Insert new content at the same position
            requests.append(
                {"insertText": {"location": {"index": del_start}, "text": text}}
            )
            # Formatting
            requests.extend(fmt_fn(del_start, text))
        else:
            insert_index, text, fmt_fn = group
            requests.append(
                {"insertText": {"location": {"index": insert_index}, "text": text}}
            )
            requests.extend(fmt_fn(insert_index, text))

    return {"requests": requests} if requests else None


# execute_batch_update, update_cache, parse_doc_entries, parse_date_from_heading,
# SECTION_MAP, parse_entry_sections, parse_subsections are all imported from
# lib.daily_log_utils


# --- Main ---


def main():
    parser = argparse.ArgumentParser(
        description="Update Task List section of the daily log"
    )
    parser.add_argument(
        "--auto-confirm",
        action="store_true",
        help="Automatically confirm the batchUpdate write",
    )
    args = parser.parse_args()
    auto_confirm = args.auto_confirm

    # Step 1: Read configs
    config, style = read_configs()
    for key in ("inProgressTaskListId", "waitingTaskListId"):
        if key not in config:
            print(f"ERROR: daily_log config missing required key: {key}", file=sys.stderr)
            sys.exit(1)
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")
    today_heading = datetime.now().strftime("%A %b %-d, %Y")

    print(f"Updating Task List for {today_heading}")
    print(f"Document ID: {doc_id}")

    # Step 2: Fetch doc and check cache freshness
    doc = fetch_doc(doc_id)
    ensure_cache_fresh(doc, doc_id)

    boundaries = get_section(doc_id, today_str, "task_list")
    if not boundaries:
        print(
            "ERROR: No cached entry for today. Run /daily-log first to create the entry.",
            file=sys.stderr,
        )
        sys.exit(1)

    tl_start, tl_end = boundaries
    print(f"Task List section: index {tl_start} to {tl_end}")

    # Step 3: Get timezone offset and fetch data
    tz_result = subprocess.run(
        ["date", "+%:z"], capture_output=True, text=True
    )
    tz_offset = tz_result.stdout.strip()

    events = fetch_calendar_events(config, today_str, tz_offset)
    in_progress_tasks, waiting_tasks = fetch_tasks(config, today_str)

    print(f"Found {len(events)} calendar event(s)")
    print(f"Found {len(in_progress_tasks)} in-progress task(s)")
    print(f"Found {len(waiting_tasks)} waiting task(s) due today")

    # Step 4: Parse current content from doc

    # Parse existing priorities from Task List section
    task_list_text = extract_section_text(doc, tl_start, tl_end)
    existing_priorities = parse_existing_priority_titles(task_list_text)

    # Parse existing waiting items
    current_waiting_titles = parse_existing_waiting_items(doc, tl_start, tl_end)

    print(f"Existing priorities: {len(existing_priorities)}")
    print(f"Existing waiting items: {len(current_waiting_titles)}")

    # Step 5: Compute diffs
    # New priority entries: events and tasks not already in the priorities list
    new_priority_events = [
        e
        for e in events
        if ("event", e["summary"]) not in existing_priorities
    ]
    new_priority_tasks = [
        t
        for t in in_progress_tasks
        if ("task", t["title"]) not in existing_priorities
    ]

    # Sort new priority entries
    new_priority_entries = sort_new_entries(new_priority_events, new_priority_tasks)

    # New waiting items: tasks not already in the waiting section
    new_waiting_items = [
        t for t in waiting_tasks if t["title"] not in current_waiting_titles
    ]

    # Determine if waiting/blockers needs updating
    # Rebuild the full set of waiting items from current + new
    all_waiting_set = current_waiting_titles | {t["title"] for t in waiting_tasks}
    waiting_changed = all_waiting_set != current_waiting_titles

    if not new_priority_entries and not waiting_changed:
        print("Task List is already up to date.")
        sys.exit(0)

    # Report what will change
    if new_priority_entries:
        print(f"\nNew priority items to add: {len(new_priority_entries)}")
        for item, item_type in new_priority_entries:
            if item_type == "event":
                print(f"  (event) {item['summary']} {format_event_time(item)}")
            else:
                print(f"  (task) {item['title']}")

    if waiting_changed:
        print(f"\nWaiting/Blockers will be updated")
        for t in new_waiting_items:
            print(f"  + {t['title']}")

    # Step 6: Find insertion points
    # Strategy B: inherit bullet list membership from existing priority bullets
    inherit_priority_bullet = False
    priorities_insert_index = find_priorities_insertion_point(doc, tl_start, tl_end)
    if priorities_insert_index is not None and new_priority_entries:
        last_priority_bullet = find_last_bullet_end_in_section(
            doc, tl_start, priorities_insert_index
        )
        if last_priority_bullet:
            priorities_insert_index = last_priority_bullet - 1  # before trailing \n
            inherit_priority_bullet = True
    if priorities_insert_index is None and new_priority_entries:
        print(
            "ERROR: could not find 'Waiting / Blockers:' label in Task List section",
            file=sys.stderr,
        )
        sys.exit(1)

    waiting_boundary = None
    if waiting_changed:
        waiting_boundary = find_subsection_boundary(
            doc, tl_start, tl_end, "\u23f3 Waiting / Blockers:"
        )
        if waiting_boundary is None:
            print(
                "ERROR: could not find 'Waiting / Blockers:' sub-section boundaries",
                file=sys.stderr,
            )
            sys.exit(1)

    # Step 7: Build batchUpdate
    batch = build_batch_update(
        new_priority_entries=new_priority_entries if new_priority_entries else [],
        new_waiting_items=waiting_tasks if waiting_changed else [],
        current_waiting_titles=current_waiting_titles if waiting_changed else set(),
        priorities_insert_index=priorities_insert_index,
        waiting_boundary=waiting_boundary,
        style=style,
        inherit_priority_bullet=inherit_priority_bullet,
    )

    if batch is None:
        print("Task List is already up to date.")
        sys.exit(0)

    # Step 8: Execute batchUpdate
    success = execute_batch_update(doc_id, batch, auto_confirm)

    if not success:
        sys.exit(2)

    # Step 9: Update cache
    update_cache(doc_id)

    # Report summary
    summary_parts = []
    if new_priority_entries:
        summary_parts.append(f"{len(new_priority_entries)} priority item(s)")
    if waiting_changed:
        summary_parts.append("waiting/blockers")

    note_msg = f"Task list updated: {', '.join(summary_parts)}."
    publish_note(note_msg, auto_confirm)

    print(f"\nDone. Updated: {', '.join(summary_parts)}.")


if __name__ == "__main__":
    main()
