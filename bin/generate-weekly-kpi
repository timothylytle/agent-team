#!/usr/bin/env python3
"""Weekly KPI report generator.

Collects helpdesk metrics, calendar event counts, task completions, and
support summary data for a Friday-through-Thursday week, prints a report,
and inserts it into the Notes section of today's daily log.

Usage:
    bin/generate-weekly-kpi [--week-ending YYYY-MM-DD] [--auto-confirm] [--dry-run]
"""

import argparse
import json
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

# Allow imports from bin/lib/
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    FRESHDESK_SAFE,
    GWS_SAFE,
    ensure_cache_fresh,
    execute_batch_update,
    fetch_doc,
    get_section,
    publish_note,
    read_configs,
    run_cmd,
    update_cache,
    utf16_len,
)


# --- Date range computation ---


def compute_week_range(week_ending_str=None):
    """Compute Friday-through-Thursday date range.

    Args:
        week_ending_str: Optional YYYY-MM-DD string for the Thursday.
            Defaults to the most recent Thursday (including today if Thursday).

    Returns:
        (week_start, week_end) as date objects (Friday and Thursday).
    """
    if week_ending_str:
        week_end = datetime.strptime(week_ending_str, "%Y-%m-%d").date()
    else:
        today = datetime.now().date()
        # Find most recent Thursday (weekday 3). If today is Thursday, use today.
        days_since_thursday = (today.weekday() - 3) % 7
        week_end = today - timedelta(days=days_since_thursday)

    week_start = week_end - timedelta(days=6)
    return week_start, week_end


# --- Data collection ---


def fetch_tickets_opened(week_start, week_end):
    """Count FreshDesk tickets created in the date range."""
    week_start_str = week_start.strftime("%Y-%m-%d")
    week_end_next_str = (week_end + timedelta(days=1)).strftime("%Y-%m-%d")
    query = f"created_at:>'{week_start_str}' AND created_at:<'{week_end_next_str}'"

    stdout, _, _ = run_cmd(
        [FRESHDESK_SAFE, "tickets", "search", "--query", query]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse FreshDesk ticket search output", file=sys.stderr)
        sys.exit(1)

    total = data.get("total", 0)
    print(f"  Tickets opened: {total}")
    return total


    # Responses to customers — from FreshDesk analytics report (manual input)
    # No FreshDesk analytics API exists, so this is provided via --responses flag


def fetch_email_requests():
    """Email requests from customers — always 0 per policy."""
    print("  Email requests: 0 (by policy)")
    return 0


def fetch_calendar_events(week_start, week_end):
    """Fetch calendar events for the date range and count by color.

    Returns:
        (color_counts, meetings) where color_counts is a dict of
        colorId -> count, and meetings is a list of (category, summary).
    """
    week_start_iso = week_start.strftime("%Y-%m-%d")
    week_end_iso = week_end.strftime("%Y-%m-%d")

    # Use local timezone offset for accurate day boundaries
    local_offset = datetime.now(timezone.utc).astimezone().strftime("%z")
    tz_str = f"{local_offset[:3]}:{local_offset[3:]}"  # e.g. "-06:00"

    params = {
        "calendarId": "primary",
        "timeMin": f"{week_start_iso}T00:00:00{tz_str}",
        "timeMax": f"{week_end_iso}T23:59:59{tz_str}",
        "singleEvents": True,
        "orderBy": "startTime",
    }

    print("  Fetching calendar events...")
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "calendar", "events", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse calendar events output", file=sys.stderr)
        sys.exit(1)

    items = data.get("items", [])

    COLOR_LABELS = {
        "4": "[support]",
        "11": "[afterhours]",
        "6": "[sales]",
        "1": "[onboarding]",
    }

    color_counts = {"4": 0, "11": 0, "6": 0, "1": 0}
    meetings = []

    for event in items:
        color_id = event.get("colorId")
        if color_id in color_counts:
            color_counts[color_id] += 1
            summary = event.get("summary", "(No title)").strip()
            label = COLOR_LABELS[color_id]
            meetings.append((label, summary))

    print(f"  Calendar events: {len(items)} total, "
          f"{color_counts['4']} support, {color_counts['11']} afterhours, "
          f"{color_counts['6']} sales, {color_counts['1']} onboarding")
    return color_counts, meetings


def fetch_completed_tasks(config, week_start, week_end):
    """Fetch tasks completed in the date range.

    Returns list of task title strings.
    """
    week_start_iso = week_start.strftime("%Y-%m-%d")
    week_end_next_iso = (week_end + timedelta(days=1)).strftime("%Y-%m-%d")

    params = {
        "tasklist": config["inProgressTaskListId"],
        "showCompleted": True,
        "showHidden": True,
        "completedMin": f"{week_start_iso}T00:00:00.000Z",
        "completedMax": f"{week_end_next_iso}T00:00:00.000Z",
    }

    print("  Fetching completed tasks...")
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "tasks", "tasks", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse tasks output", file=sys.stderr)
        sys.exit(1)

    tasks = []
    for item in data.get("items", []):
        title = item.get("title", "").strip()
        if title:
            tasks.append(title)

    print(f"  Completed tasks: {len(tasks)}")
    return tasks


def fetch_upcoming_tasks(config):
    """Fetch current in-progress tasks.

    Returns list of task title strings.
    """
    params = {"tasklist": config["inProgressTaskListId"]}

    print("  Fetching upcoming tasks...")
    stdout, _, _ = run_cmd(
        [GWS_SAFE, "tasks", "tasks", "list", "--params", json.dumps(params)]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse tasks output", file=sys.stderr)
        sys.exit(1)

    tasks = []
    for item in data.get("items", []):
        title = item.get("title", "").strip()
        if title:
            tasks.append(title)

    print(f"  Upcoming tasks: {len(tasks)}")
    return tasks


def fetch_tickets_assigned():
    """Count non-closed tickets (status 2, 3, 6, 7, 9)."""
    query = "status:2 OR status:3 OR status:6 OR status:7 OR status:9"
    stdout, _, _ = run_cmd(
        [FRESHDESK_SAFE, "tickets", "search", "--query", query]
    )
    try:
        data = json.loads(stdout)
    except json.JSONDecodeError:
        print("ERROR: failed to parse FreshDesk search output", file=sys.stderr)
        sys.exit(1)

    count = data.get("total", 0)
    print(f"  Tickets assigned: {count}")
    return count


    # Tickets resolved — from FreshDesk analytics report (manual input)
    # No FreshDesk analytics API exists, so this is provided via --resolved flag


# --- Report formatting ---


def format_report(week_start, week_end, tickets_opened, responses,
                  email_requests, color_counts, meetings, completed_tasks,
                  upcoming_tasks, tickets_assigned, tickets_resolved):
    """Build the report data.

    Returns (heading, table_data, body_text) where:
    - heading is the HEADING_3 title line
    - table_data is a list of (label, value) tuples for the helpdesk table
    - body_text is the remaining NORMAL_TEXT content (Meetings, Tasks, Summary)
    """
    start_label = week_start.strftime("%b %-d")
    end_label = week_end.strftime("%b %-d")
    heading = f"KPI \u2014 Week of {start_label}\u2013{end_label}"

    # Support Calls = support + afterhours + onboarding combined
    support_calls = color_counts["4"] + color_counts["11"] + color_counts["1"]

    table_data = [
        ("Metric", "Count"),  # header
        ("Number of Opened Helpdesk Tickets this week", str(tickets_opened)),
        ("HelpDesk Responses to Customers", str(responses)),
        ("Number of Received Email Requests from Customers", str(email_requests)),
        ("Number of Support Calls with Customers", str(support_calls)),
        ("Number of After Hours Support", str(color_counts["11"])),
        ("Number of Sales Calls with Expert Engineer", str(color_counts["6"])),
    ]

    lines = []
    lines.append("Meetings:")
    if meetings:
        for label, summary in meetings:
            lines.append(f"  {label} {summary}")
    else:
        lines.append("  (none)")

    lines.append("")
    lines.append("Completed Tasks:")
    if completed_tasks:
        for task in completed_tasks:
            lines.append(f"  \u2022 {task}")
    else:
        lines.append("  (none)")

    lines.append("")
    lines.append("Upcoming Tasks:")
    if upcoming_tasks:
        for task in upcoming_tasks:
            lines.append(f"  \u2022 {task}")
    else:
        lines.append("  (none)")

    lines.append("")
    lines.append("Support Summary:")
    lines.append(f"  Tickets Assigned: {tickets_assigned}")
    lines.append(f"  Tickets Resolved: {tickets_resolved}")
    lines.append(f"  Responses to Customers: {responses}")

    body_text = "\n".join(lines)
    return heading, table_data, body_text


# --- Doc insertion ---


def insert_kpi_heading_and_table(doc_id, heading, insert_index, style, auto_confirm):
    """Step 1: Insert the HEADING_3 title and an empty 7x2 table.

    Returns True if the batchUpdate succeeded, False otherwise.
    """
    heading_text = heading + "\n"
    heading_start = insert_index
    heading_end = insert_index + utf16_len(heading_text)

    requests = []

    # 1. Insert heading text
    requests.append({
        "insertText": {
            "location": {"index": insert_index},
            "text": heading_text,
        }
    })

    # 2. Apply HEADING_3 paragraph style
    requests.append({
        "updateParagraphStyle": {
            "range": {"startIndex": heading_start, "endIndex": heading_end},
            "paragraphStyle": {"namedStyleType": "HEADING_3"},
            "fields": "namedStyleType",
        }
    })

    # 3. Apply heading font styling
    heading_text_style = {
        "weightedFontFamily": {"fontFamily": style["fonts"]["heading"]}
    }
    heading_fields = "weightedFontFamily"
    if style["colors"].get("headingText"):
        heading_text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["headingText"]}
        }
        heading_fields += ",foregroundColor"

    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": heading_start, "endIndex": heading_end},
            "textStyle": heading_text_style,
            "fields": heading_fields,
        }
    })

    # 4. Insert empty table (7 rows, 2 columns) right after the heading
    requests.append({
        "insertTable": {
            "location": {"index": heading_end},
            "rows": 7,
            "columns": 2,
        }
    })

    batch = {"requests": requests}
    return execute_batch_update(doc_id, batch, auto_confirm)


def populate_table_and_body(doc_id, table_data, body_text, style, auto_confirm,
                            expected_table_after):
    """Step 2: Populate table cells, style them, and add remaining body text.

    Reads the doc to find real table indices, then builds a batchUpdate
    to fill cells (reverse order), style them, and append body text.

    Args:
        expected_table_after: the index where the heading was inserted.
            Used to find the correct table (the one right after our heading).

    Returns True if the batchUpdate succeeded, False otherwise.
    """
    doc = fetch_doc(doc_id)
    body_content = doc["body"]["content"]

    # Find the table element nearest to (and after) our heading insertion point.
    # We can't just use "last table" because old KPI tables may exist in the doc.
    table_element = None
    for element in body_content:
        if "table" in element and element["startIndex"] >= expected_table_after:
            table_element = element
            break

    if not table_element:
        print("ERROR: could not find inserted table in document", file=sys.stderr)
        sys.exit(1)

    table = table_element["table"]
    table_end = table_element["endIndex"]

    # Collect cell insertion points: (row_idx, col_idx, startIndex)
    cell_indices = []
    for row_idx, row in enumerate(table["tableRows"]):
        for col_idx, cell in enumerate(row["tableCells"]):
            cell_start = cell["content"][0]["paragraph"]["elements"][0]["startIndex"]
            cell_indices.append((row_idx, col_idx, cell_start))

    requests = []

    # Insert cell text in reverse order (bottom-right to top-left)
    for row_idx, col_idx, cell_start in reversed(cell_indices):
        text = table_data[row_idx][col_idx]
        requests.append({
            "insertText": {
                "location": {"index": cell_start},
                "text": text,
            }
        })

    # After text insertion, indices shift. Re-read doc for styling.
    # Instead, calculate the shifts and apply styles in the same batch.
    # Since we insert in reverse order, earlier indices are not affected.
    # We can compute final ranges by accumulating shifts forward.

    # Build a shift map: for each cell, how much text was inserted before it
    # Since we insert in reverse order within the same batch, all inserts
    # happen at their original indices. The Docs API processes requests
    # sequentially, so earlier inserts shift later indices.
    # We inserted in reverse order, so the first request inserts at the
    # highest index (bottom-right), which doesn't affect lower indices.
    # This means each cell's text lands at its original startIndex.

    # Calculate styled ranges after all inserts
    # Process cells in forward order to accumulate shifts
    cumulative_shift = 0
    styled_ranges = []
    for row_idx, col_idx, cell_start in cell_indices:
        text = table_data[row_idx][col_idx]
        text_len = utf16_len(text)
        actual_start = cell_start + cumulative_shift
        actual_end = actual_start + text_len
        styled_ranges.append((row_idx, col_idx, actual_start, actual_end))
        cumulative_shift += text_len

    # Apply bold to header row (row 0)
    for row_idx, col_idx, start, end in styled_ranges:
        if row_idx == 0:
            requests.append({
                "updateTextStyle": {
                    "range": {"startIndex": start, "endIndex": end},
                    "textStyle": {"bold": True},
                    "fields": "bold",
                }
            })

    # Apply NORMAL_TEXT paragraph style to all table cells so they don't
    # inherit HEADING_3 sizing from the preceding heading
    for row_idx, col_idx, start, end in styled_ranges:
        # Range must cover the paragraph including its trailing newline
        requests.append({
            "updateParagraphStyle": {
                "range": {"startIndex": start, "endIndex": end + 1},
                "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
                "fields": "namedStyleType",
            }
        })

    # Apply Roboto font + explicit 11pt size to all cells
    body_font = style["fonts"]["body"]
    for row_idx, col_idx, start, end in styled_ranges:
        requests.append({
            "updateTextStyle": {
                "range": {"startIndex": start, "endIndex": end},
                "textStyle": {
                    "weightedFontFamily": {"fontFamily": body_font},
                    "fontSize": {"magnitude": 11, "unit": "PT"},
                },
                "fields": "weightedFontFamily,fontSize",
            }
        })

    # Set column widths
    requests.append({
        "updateTableColumnProperties": {
            "tableStartLocation": {"index": table_element["startIndex"]},
            "columnIndices": [0],
            "tableColumnProperties": {
                "widthType": "FIXED_WIDTH",
                "width": {"magnitude": 350, "unit": "PT"},
            },
            "fields": "widthType,width",
        }
    })
    requests.append({
        "updateTableColumnProperties": {
            "tableStartLocation": {"index": table_element["startIndex"]},
            "columnIndices": [1],
            "tableColumnProperties": {
                "widthType": "FIXED_WIDTH",
                "width": {"magnitude": 50, "unit": "PT"},
            },
            "fields": "widthType,width",
        }
    })

    # Insert remaining body text after the table
    body_insert_text = body_text + "\n"
    adjusted_table_end = table_end + cumulative_shift
    requests.append({
        "insertText": {
            "location": {"index": adjusted_table_end},
            "text": body_insert_text,
        }
    })

    # Apply NORMAL_TEXT style to body text
    body_text_start = adjusted_table_end
    body_text_end = adjusted_table_end + utf16_len(body_insert_text)
    requests.append({
        "updateParagraphStyle": {
            "range": {"startIndex": body_text_start, "endIndex": body_text_end},
            "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
            "fields": "namedStyleType",
        }
    })

    # Apply body font to body text
    body_text_style = {
        "weightedFontFamily": {"fontFamily": body_font}
    }
    body_fields = "weightedFontFamily"
    if style["colors"].get("bodyText"):
        body_text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["bodyText"]}
        }
        body_fields += ",foregroundColor"

    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": body_text_start, "endIndex": body_text_end},
            "textStyle": body_text_style,
            "fields": body_fields,
        }
    })

    batch = {"requests": requests}
    return execute_batch_update(doc_id, batch, auto_confirm)


# --- Main ---


def main():
    parser = argparse.ArgumentParser(
        description="Generate weekly KPI report and insert into daily log"
    )
    parser.add_argument(
        "--week-ending",
        help="Thursday ending the report week (YYYY-MM-DD). "
             "Defaults to most recent Thursday.",
    )
    parser.add_argument(
        "--auto-confirm", action="store_true",
        help="Automatically confirm GWS writes",
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Show report without inserting into doc",
    )
    parser.add_argument(
        "--responses", type=int, default=None,
        help="Responses to customers (from FreshDesk analytics report)",
    )
    parser.add_argument(
        "--resolved", type=int, default=None,
        help="Tickets resolved (from FreshDesk analytics report)",
    )
    args = parser.parse_args()

    # Step 1: Compute date range
    week_start, week_end = compute_week_range(args.week_ending)
    print(f"Weekly KPI Report: {week_start} (Fri) through {week_end} (Thu)")
    print()

    # Step 2: Collect data
    print("Collecting data...")
    tickets_opened = fetch_tickets_opened(week_start, week_end)
    email_requests = fetch_email_requests()
    color_counts, meetings = fetch_calendar_events(week_start, week_end)
    config, style = read_configs()
    completed_tasks = fetch_completed_tasks(config, week_start, week_end)
    upcoming_tasks = fetch_upcoming_tasks(config)
    tickets_assigned = fetch_tickets_assigned()

    # Manual-input fields from FreshDesk analytics report
    responses = args.responses
    if responses is None:
        responses = "___"
        print("  Responses to customers: (provide via --responses)")
    else:
        print(f"  Responses to customers: {responses}")

    tickets_resolved = args.resolved
    if tickets_resolved is None:
        tickets_resolved = "___"
        print("  Tickets resolved: (provide via --resolved)")
    else:
        print(f"  Tickets resolved: {tickets_resolved}")

    # Step 3: Format report
    heading, table_data, body_text = format_report(
        week_start, week_end, tickets_opened, responses, email_requests,
        color_counts, meetings, completed_tasks, upcoming_tasks,
        tickets_assigned, tickets_resolved,
    )

    print()
    print("=" * 60)
    print(heading)
    print()
    for label, value in table_data:
        print(f"  {label}: {value}")
    print()
    print(body_text)
    print("=" * 60)
    print()

    if args.dry_run:
        print("Dry-run mode: report not inserted into daily log.")
        return

    # Step 4: Insert into daily log (two-step batchUpdate)
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")

    doc = fetch_doc(doc_id)
    ensure_cache_fresh(doc, doc_id)

    boundaries = get_section(doc_id, today_str, "notes")
    if not boundaries:
        print(
            "ERROR: No cached entry for today. Run /daily-log first to create the entry.",
            file=sys.stderr,
        )
        sys.exit(1)

    section_start, section_end = boundaries
    print(f"Notes section: index {section_start} to {section_end}")

    # Insert at the end of the Notes section
    insert_index = section_end
    print(f"Insert index: {insert_index}")

    # Step 4a: Insert heading and empty table
    print("\nStep 1: Inserting heading and table...")
    success = insert_kpi_heading_and_table(
        doc_id, heading, insert_index, style, args.auto_confirm,
    )
    if not success:
        sys.exit(2)

    # Step 4b: Populate table cells and add body text
    print("\nStep 2: Populating table and adding body text...")
    success = populate_table_and_body(
        doc_id, table_data, body_text, style, args.auto_confirm,
        expected_table_after=insert_index,
    )
    if not success:
        sys.exit(2)

    # Step 5: Update cache
    update_cache(doc_id)

    # Step 6: Publish note
    start_label = week_start.strftime("%b %-d")
    end_label = week_end.strftime("%b %-d")
    publish_note(
        f"Weekly KPI generated for {start_label}-{end_label}",
        args.auto_confirm,
    )

    print("\nDone. KPI report inserted into Notes section.")


if __name__ == "__main__":
    main()
