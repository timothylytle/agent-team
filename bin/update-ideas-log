#!/usr/bin/env python3
"""Ideas log updater.

Adds an entry to the Thoughts / Ideas section of today's daily log.

Usage (card format):
    bin/update-ideas-log --json '{"title":"...","pros":["..."],"cons":["..."],"recommendation":"..."}' [--auto-confirm]

Usage (legacy bullet format):
    bin/update-ideas-log --title "Idea title" --analysis "Brief analysis" [--source-url "https://..."] [--auto-confirm]
"""

import argparse
import json
import sys
from datetime import datetime
from pathlib import Path

# Allow imports from bin/lib/
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    ensure_cache_fresh,
    execute_batch_update,
    extract_section_text,
    fetch_doc,
    find_last_bullet_end_in_section,
    get_section,
    publish_note,
    read_configs,
    update_cache,
    utf16_len,
)


# --- Step 5: Build batchUpdate ---

def build_batch_update(line_text, insert_index, style, inherit_bullet=False):
    """Build the batchUpdate JSON for inserting a new idea line.

    When inherit_bullet is True, inserts at last_bullet_end - 1 (before the
    existing paragraph's trailing newline). The leading \\n splits the existing
    paragraph and new paragraphs inherit bullet membership, paragraph style,
    and font styling automatically.

    When inherit_bullet is False (fallback), inserts at section_end with
    explicit paragraph style, bullet creation, and font styling.
    """
    if inherit_bullet:
        insert_text = "\n" + line_text
    else:
        insert_text = line_text + "\n"

    requests = []

    # 1. Insert text
    requests.append({
        "insertText": {
            "location": {"index": insert_index},
            "text": insert_text,
        }
    })

    if inherit_bullet:
        # Clear strikethrough that may be inherited from checked checkboxes
        text_start = insert_index + utf16_len("\n")
        text_end = insert_index + utf16_len(insert_text)
        requests.append({
            "updateTextStyle": {
                "range": {"startIndex": text_start, "endIndex": text_end},
                "textStyle": {"strikethrough": False},
                "fields": "strikethrough",
            }
        })
    else:
        # Fallback: explicit paragraph style, bullets, and font styling
        text_start = insert_index
        text_end = insert_index + utf16_len(insert_text)

        # 2. Reset paragraph style to NORMAL_TEXT
        requests.append({
            "updateParagraphStyle": {
                "range": {
                    "startIndex": text_start,
                    "endIndex": text_end,
                },
                "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
                "fields": "namedStyleType",
            }
        })

        # 3. Apply checkbox bullets
        requests.append({
            "createParagraphBullets": {
                "range": {
                    "startIndex": text_start,
                    "endIndex": text_end,
                },
                "bulletPreset": style["bulletPresets"]["checkbox"],
            }
        })

        # 4. Apply font styling
        text_style = {
            "weightedFontFamily": {
                "fontFamily": style["fonts"]["body"],
            }
        }
        fields = "weightedFontFamily"

        if style["colors"].get("bodyText"):
            text_style["foregroundColor"] = {
                "color": {"rgbColor": style["colors"]["bodyText"]}
            }
            fields += ",foregroundColor"

        requests.append({
            "updateTextStyle": {
                "range": {
                    "startIndex": text_start,
                    "endIndex": text_end,
                },
                "textStyle": text_style,
                "fields": fields,
            }
        })

    return {"requests": requests}


def build_batch_update_card(idea_data, insert_index, style):
    """Build the batchUpdate JSON for inserting an idea card.

    Card format (plain text, no bullets):
        Idea Title          (bold, optionally linked)
        + Pro one
        + Pro two
        - Con one
        - Con two
        Recommendation: Brief recommendation text
    """
    lines = [idea_data["title"]]
    for pro in idea_data.get("pros", []):
        lines.append(f"+ {pro}")
    for con in idea_data.get("cons", []):
        lines.append(f"- {con}")
    if idea_data.get("recommendation"):
        lines.append(f"Recommendation: {idea_data['recommendation']}")

    card_text = "\n".join(lines)
    insert_text = card_text + "\n"

    requests = []

    # 1. Insert full text block
    requests.append({
        "insertText": {
            "location": {"index": insert_index},
            "text": insert_text,
        }
    })

    text_start = insert_index
    text_end = insert_index + utf16_len(insert_text)

    # 2. NORMAL_TEXT paragraph style
    requests.append({
        "updateParagraphStyle": {
            "range": {"startIndex": text_start, "endIndex": text_end},
            "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
            "fields": "namedStyleType",
        }
    })

    # 3. Body font to all text
    text_style = {
        "weightedFontFamily": {"fontFamily": style["fonts"]["body"]}
    }
    fields = "weightedFontFamily"
    if style["colors"].get("bodyText"):
        text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["bodyText"]}
        }
        fields += ",foregroundColor"

    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": text_start, "endIndex": text_end},
            "textStyle": text_style,
            "fields": fields,
        }
    })

    # 4. Bold the title line
    title_end = insert_index + utf16_len(idea_data["title"])
    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": text_start, "endIndex": title_end},
            "textStyle": {"bold": True},
            "fields": "bold",
        }
    })

    # 5. Link on title if source_url provided
    if idea_data.get("source_url"):
        requests.append({
            "updateTextStyle": {
                "range": {"startIndex": text_start, "endIndex": title_end},
                "textStyle": {"link": {"url": idea_data["source_url"]}},
                "fields": "link",
            }
        })

    return {"requests": requests}


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Add an entry to the Thoughts / Ideas section of the daily log")
    parser.add_argument("--json", dest="json_data", help="JSON object with title, pros, cons, recommendation, source_url")
    parser.add_argument("--title", help="Idea title (legacy format)")
    parser.add_argument("--analysis", help="Brief analysis text (legacy format)")
    parser.add_argument("--source-url", help="Optional source URL (legacy format)")
    parser.add_argument("--auto-confirm", action="store_true", help="Automatically confirm the batchUpdate write")
    parser.add_argument("--dry-run", action="store_true", help="Print batchUpdate payload without executing")
    args = parser.parse_args()
    auto_confirm = args.auto_confirm

    # Determine mode: card (--json) or legacy (--title/--analysis)
    use_card = False
    if args.json_data:
        use_card = True
        idea_data = json.loads(args.json_data)
        if "title" not in idea_data:
            print("ERROR: --json must include 'title'", file=sys.stderr)
            sys.exit(1)
        idea_title = idea_data["title"]
    elif args.title and args.analysis:
        idea_title = args.title
        line_text = f"{args.title} \u2014 {args.analysis}"
        if args.source_url:
            line_text += f" \u2014 {args.source_url}"
    else:
        print("ERROR: must provide --json or both --title and --analysis", file=sys.stderr)
        sys.exit(1)

    # Step 1: Read configs
    config, style = read_configs()
    doc_id = config["documentId"]
    today_str = datetime.now().strftime("%Y-%m-%d")
    today_heading = datetime.now().strftime("%A %b %-d, %Y")

    print(f"Adding idea to Thoughts / Ideas for {today_heading}")
    print(f"Document ID: {doc_id}")

    # Step 2: Fetch doc and check cache freshness
    doc = fetch_doc(doc_id)
    ensure_cache_fresh(doc, doc_id)

    boundaries = get_section(doc_id, today_str, "thoughts_ideas")
    if not boundaries:
        print("ERROR: No cached entry for today. Run /daily-log first to create the entry.", file=sys.stderr)
        sys.exit(1)

    section_start, section_end = boundaries
    print(f"Thoughts / Ideas section: index {section_start} to {section_end}")

    # Step 3: Extract current section text
    section_text = extract_section_text(doc, section_start, section_end)
    print(f"Current section text: {repr(section_text[:100])}...")

    # Step 4: Build and execute batchUpdate
    if use_card:
        insert_index = section_end
        print(f"Insert index: {insert_index} (card format)")
        batch = build_batch_update_card(idea_data, insert_index, style)
    else:
        last_bullet = find_last_bullet_end_in_section(doc, section_start, section_end)
        if last_bullet:
            insert_index = last_bullet - 1  # before the trailing \n
            inherit_bullet = True
        else:
            insert_index = section_end  # fallback: no existing bullets
            inherit_bullet = False

        print(f"Insert index: {insert_index} (inherit_bullet={inherit_bullet})")
        print(f"Line: {line_text}")
        batch = build_batch_update(line_text, insert_index, style, inherit_bullet)

    if args.dry_run:
        print("\n[dry-run] batchUpdate payload:")
        print(json.dumps(batch, indent=2))
        return

    success = execute_batch_update(doc_id, batch, auto_confirm)

    if not success:
        sys.exit(2)

    # Step 5: Update cache
    update_cache(doc_id)

    publish_note(f"Idea added: {idea_title}", auto_confirm)

    print(f"\nDone. Added idea to Thoughts / Ideas section:")
    print(f"  {idea_title}")


if __name__ == "__main__":
    main()
