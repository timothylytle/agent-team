#!/usr/bin/env python3
"""One-off migration script to update today's live daily log entry.

Applies three formatting changes in separate passes (re-fetching the doc
between each to avoid index drift):

  Pass 1: Add colons to "Task List" and "Notes" headings
  Pass 2: Move Random Fact from Task List to its own HEADING_2 section
  Pass 3: Convert Notes URL lines to inline [event]/[task] link labels

Usage:
    bin/migrate-daily-log-format [--auto-confirm]
"""

import argparse
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.daily_log_utils import (
    execute_batch_update,
    fetch_doc,
    read_configs,
    update_cache,
    utf16_len,
)


# --- Helpers ---


def find_entry_bounds(body_content, today_heading):
    """Find today's entry start and end indices."""
    entry_start = None
    entry_end = None
    for element in body_content:
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") == "HEADING_1":
            text = ""
            for pe in paragraph.get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            if text.strip() == today_heading:
                entry_start = element.get("startIndex", 0)
                entry_end = body_content[-1].get("endIndex", 0)
                for el2 in body_content:
                    el2_start = el2.get("startIndex", 0)
                    if el2_start <= entry_start:
                        continue
                    p2 = el2.get("paragraph", {})
                    ps2 = p2.get("paragraphStyle", {})
                    if ps2.get("namedStyleType") == "HEADING_1":
                        entry_end = el2_start
                        break
                break
    return entry_start, entry_end


def find_heading2(body_content, entry_start, entry_end, heading_text):
    """Find a HEADING_2 paragraph matching heading_text exactly.
    Returns (start_index, end_index) or None."""
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start < entry_start or el_start >= entry_end:
            continue
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") != "HEADING_2":
            continue
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        if text.strip() == heading_text:
            return el_start, element.get("endIndex", 0)
    return None


def find_label_line(body_content, section_start, section_end, label_text):
    """Find a NORMAL_TEXT paragraph containing label_text.
    Returns (start_index, end_index) or None."""
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_start < section_start or el_start >= section_end:
            continue
        paragraph = element.get("paragraph", {})
        text = ""
        for pe in paragraph.get("elements", []):
            text += pe.get("textRun", {}).get("content", "")
        if label_text in text.strip():
            return el_start, el_end
    return None


# --- Pass 1: Add colons ---


def pass_add_colons(doc_id, style, auto_confirm):
    """Add colons to Task List and Notes headings."""
    print("\n=== Pass 1: Add colons to headings ===")
    doc = fetch_doc(doc_id)
    body_content = doc.get("body", {}).get("content", [])
    today_heading = datetime.now().strftime("%A %b %-d, %Y")
    entry_start, entry_end = find_entry_bounds(body_content, today_heading)
    if entry_start is None:
        print(f"ERROR: Could not find today's entry ({today_heading})", file=sys.stderr)
        sys.exit(1)

    requests = []

    # Process from higher index to lower to avoid index shift
    notes_h2 = find_heading2(body_content, entry_start, entry_end, "Notes")
    task_list_h2 = find_heading2(body_content, entry_start, entry_end, "Task List")

    targets = []
    if notes_h2:
        targets.append(("Notes", notes_h2))
    if task_list_h2:
        targets.append(("Task List", task_list_h2))

    # Sort by start index descending
    targets.sort(key=lambda x: x[1][0], reverse=True)

    for name, (h_start, h_end) in targets:
        colon_index = h_end - 1  # before trailing newline
        requests.append({
            "insertText": {
                "location": {"index": colon_index},
                "text": ":",
            }
        })
        print(f"  Adding colon to '{name}'")

    if not requests:
        print("  No headings need colons (already have them)")
        return False

    batch = {"requests": requests}
    return execute_batch_update(doc_id, batch, auto_confirm)


# --- Pass 2: Move Random Fact ---


def pass_move_random_fact(doc_id, style, auto_confirm):
    """Move Random Fact from inside Task List to its own HEADING_2 section."""
    print("\n=== Pass 2: Move Random Fact to its own section ===")
    doc = fetch_doc(doc_id)
    body_content = doc.get("body", {}).get("content", [])
    today_heading = datetime.now().strftime("%A %b %-d, %Y")
    entry_start, entry_end = find_entry_bounds(body_content, today_heading)
    if entry_start is None:
        print(f"ERROR: Could not find today's entry ({today_heading})", file=sys.stderr)
        sys.exit(1)

    # Check if Random Fact already exists as HEADING_2
    rf_h2 = find_heading2(body_content, entry_start, entry_end, "Random Fact:")
    if rf_h2:
        print("  Random Fact already has its own HEADING_2 section")
        return False

    # Find section boundaries
    ot_h2 = find_heading2(body_content, entry_start, entry_end, "Open Tickets:")
    ti_h2 = find_heading2(body_content, entry_start, entry_end, "Thoughts / Ideas:")
    if not ot_h2 or not ti_h2:
        print("ERROR: Could not find Open Tickets or Thoughts / Ideas headings", file=sys.stderr)
        sys.exit(1)

    ot_start = ot_h2[0]
    ti_start = ti_h2[0]

    # Find Random Fact label (with emoji) inside Task List section
    # Task List ends where Open Tickets begins
    rf_label = find_label_line(body_content, entry_start, ot_start, "\U0001f3b2 Random Fact:")
    if not rf_label:
        rf_label = find_label_line(body_content, entry_start, ot_start, "Random Fact:")
    if not rf_label:
        print("  WARNING: Could not find Random Fact label in Task List")
        return False

    rf_start, rf_end = rf_label

    # Find the fact text line (next element after the label)
    fact_text = "No historical fact provided."
    fact_end = rf_end
    for element in body_content:
        el_start = element.get("startIndex", 0)
        el_end = element.get("endIndex", 0)
        if el_start >= rf_end and el_start < ot_start:
            text = ""
            for pe in element.get("paragraph", {}).get("elements", []):
                text += pe.get("textRun", {}).get("content", "")
            fact_text = text.strip()
            fact_end = el_end
            break

    requests = []

    # Step 1: Insert new Random Fact section before Thoughts / Ideas
    new_rf_text = f"Random Fact:\n{fact_text}\n"
    requests.append({
        "insertText": {
            "location": {"index": ti_start},
            "text": new_rf_text,
        }
    })

    # Step 2: Format the new heading as HEADING_2
    rf_heading_end = ti_start + utf16_len("Random Fact:\n")
    requests.append({
        "updateParagraphStyle": {
            "range": {"startIndex": ti_start, "endIndex": rf_heading_end},
            "paragraphStyle": {"namedStyleType": "HEADING_2"},
            "fields": "namedStyleType",
        }
    })

    # Step 3: Heading font
    heading_text_style = {
        "weightedFontFamily": {"fontFamily": style["fonts"]["heading"]}
    }
    heading_fields = "weightedFontFamily"
    if style["colors"].get("headingText"):
        heading_text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["headingText"]}
        }
        heading_fields += ",foregroundColor"
    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": ti_start, "endIndex": rf_heading_end},
            "textStyle": heading_text_style,
            "fields": heading_fields,
        }
    })

    # Step 4: Set fact text paragraph to NORMAL_TEXT
    fact_text_start = rf_heading_end
    fact_text_end = ti_start + utf16_len(new_rf_text)
    requests.append({
        "updateParagraphStyle": {
            "range": {"startIndex": fact_text_start, "endIndex": fact_text_end},
            "paragraphStyle": {"namedStyleType": "NORMAL_TEXT"},
            "fields": "namedStyleType",
        }
    })

    # Step 5: Body font on fact text
    body_text_style = {
        "weightedFontFamily": {"fontFamily": style["fonts"]["body"]}
    }
    body_fields = "weightedFontFamily"
    if style["colors"].get("bodyText"):
        body_text_style["foregroundColor"] = {
            "color": {"rgbColor": style["colors"]["bodyText"]}
        }
        body_fields += ",foregroundColor"
    requests.append({
        "updateTextStyle": {
            "range": {"startIndex": fact_text_start, "endIndex": fact_text_end},
            "textStyle": body_text_style,
            "fields": body_fields,
        }
    })

    # Step 6: Delete old Random Fact label + content from Task List
    # The insert above shifted indices, so we need to account for that.
    # The insert was at ti_start, and added utf16_len(new_rf_text) characters.
    # rf_start and fact_end are both before ti_start, so they are NOT shifted.
    requests.append({
        "deleteContentRange": {
            "range": {
                "startIndex": rf_start,
                "endIndex": fact_end,
            }
        }
    })

    print(f"  Moving Random Fact (delete {rf_start}-{fact_end}, insert at {ti_start})")

    batch = {"requests": requests}
    return execute_batch_update(doc_id, batch, auto_confirm)


# --- Pass 3: Convert Notes URL lines to inline links ---


def pass_convert_notes_links(doc_id, style, auto_confirm):
    """Convert Notes sub-heading URL lines to inline [event]/[task] link labels."""
    print("\n=== Pass 3: Convert Notes URL lines to inline links ===")
    doc = fetch_doc(doc_id)
    body_content = doc.get("body", {}).get("content", [])
    today_heading = datetime.now().strftime("%A %b %-d, %Y")
    entry_start, entry_end = find_entry_bounds(body_content, today_heading)
    if entry_start is None:
        print(f"ERROR: Could not find today's entry ({today_heading})", file=sys.stderr)
        sys.exit(1)

    # Find Notes section
    notes_h2 = find_heading2(body_content, entry_start, entry_end, "Notes:")
    if not notes_h2:
        print("  Notes section not found")
        return False

    notes_start = notes_h2[0]

    # Find HEADING_3 + URL line pairs
    elements_in_range = []
    for element in body_content:
        el_start = element.get("startIndex", 0)
        if el_start < notes_start or el_start >= entry_end:
            continue
        elements_in_range.append(element)

    url_headings = []
    for i, element in enumerate(elements_in_range):
        paragraph = element.get("paragraph", {})
        pstyle = paragraph.get("paragraphStyle", {})
        if pstyle.get("namedStyleType") != "HEADING_3":
            continue

        heading_text = ""
        for pe in paragraph.get("elements", []):
            heading_text += pe.get("textRun", {}).get("content", "")
        heading_text = heading_text.strip()
        heading_start = element.get("startIndex", 0)
        heading_end = element.get("endIndex", 0)

        if i + 1 >= len(elements_in_range):
            continue

        next_el = elements_in_range[i + 1]
        next_para = next_el.get("paragraph", {})
        next_style = next_para.get("paragraphStyle", {})
        if next_style.get("namedStyleType") != "NORMAL_TEXT":
            continue

        url_text = ""
        url_link = None
        for pe in next_para.get("elements", []):
            tr = pe.get("textRun", {})
            url_text += tr.get("content", "")
            ts = tr.get("textStyle", {})
            link = ts.get("link", {})
            if link.get("url"):
                url_link = link["url"]
        url_text = url_text.strip()
        if url_link and (url_text.startswith("http") or "google.com" in url_text):
            # Determine if event or task
            link_label = "event"
            for el in body_content:
                el_s = el.get("startIndex", 0)
                if el_s < entry_start or el_s >= entry_end:
                    continue
                p = el.get("paragraph", {})
                t = ""
                for pe in p.get("elements", []):
                    t += pe.get("textRun", {}).get("content", "")
                t = t.strip()
                if f"(task) {heading_text}" in t:
                    link_label = "task"
                    break

            url_headings.append({
                "heading_text": heading_text,
                "heading_start": heading_start,
                "heading_end": heading_end,
                "url_line_start": next_el.get("startIndex", 0),
                "url_line_end": next_el.get("endIndex", 0),
                "url": url_link,
                "link_label": link_label,
            })

    if not url_headings:
        print("  No Notes URL lines found to convert")
        return False

    # Process one at a time, from bottom to top, in a single batch.
    # Within each heading: first delete the URL line (lower position),
    # then insert the label (higher position). But since Google Docs
    # processes sequentially, we need to order carefully.
    #
    # For each heading (processed bottom-to-top):
    #   1. Delete the URL line (it's after the heading)
    #   2. Insert " [event]" into the heading (before its newline)
    #   3. Apply link style to the inserted text
    #
    # Since we process bottom-to-top, higher-index operations come first.
    requests = []
    for item in reversed(url_headings):
        label_text = f" [{item['link_label']}]"
        insert_pos = item["heading_end"] - 1  # before trailing newline

        # Delete URL line first (it's after the heading, so higher index)
        requests.append({
            "deleteContentRange": {
                "range": {
                    "startIndex": item["url_line_start"],
                    "endIndex": item["url_line_end"],
                }
            }
        })

        # Insert label text into heading
        # After the delete above, the heading_end hasn't changed because
        # the URL line was after the heading. insert_pos is still valid.
        requests.append({
            "insertText": {
                "location": {"index": insert_pos},
                "text": label_text,
            }
        })

        # Apply hyperlink to inserted label
        requests.append({
            "updateTextStyle": {
                "range": {
                    "startIndex": insert_pos,
                    "endIndex": insert_pos + utf16_len(label_text),
                },
                "textStyle": {"link": {"url": item["url"]}},
                "fields": "link",
            }
        })

        print(f"  Converting '{item['heading_text']}' URL to [{item['link_label']}]")

    batch = {"requests": requests}
    return execute_batch_update(doc_id, batch, auto_confirm)


# --- Main ---


def main():
    parser = argparse.ArgumentParser(
        description="One-off migration to update daily log format"
    )
    parser.add_argument(
        "--auto-confirm",
        action="store_true",
        help="Automatically confirm each batchUpdate write",
    )
    args = parser.parse_args()

    config, style = read_configs()
    doc_id = config["documentId"]

    any_changes = False

    result = pass_add_colons(doc_id, style, args.auto_confirm)
    if result:
        any_changes = True

    result = pass_move_random_fact(doc_id, style, args.auto_confirm)
    if result:
        any_changes = True

    result = pass_convert_notes_links(doc_id, style, args.auto_confirm)
    if result:
        any_changes = True

    if any_changes:
        update_cache(doc_id)
        print("\nMigration complete. Cache updated.")
    else:
        print("\nNo changes were needed.")


if __name__ == "__main__":
    main()
