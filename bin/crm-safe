#!/usr/bin/env python3
"""CRM-safe wrapper for the local SQLite CRM database.

Provides a CLI interface with dry-run/confirmation enforcement for write
operations and parameterized queries for all database access.

Usage: crm-safe <resource> <action> [options]
"""

import argparse
import hashlib
import json
import os
import sqlite3
import sys
import time
from datetime import datetime, timezone

# --- Paths ---

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH = os.path.join(SCRIPT_DIR, '..', 'db', 'crm.db')
LOG_DIR = os.path.join(SCRIPT_DIR, '..', 'logs')
LOG_FILE = os.path.join(LOG_DIR, 'crm-safe.log')
NONCE_DIR = '/tmp/crm-safe-nonces'

# --- Logging ---

def init():
    os.makedirs(LOG_DIR, exist_ok=True)
    os.makedirs(NONCE_DIR, exist_ok=True)
    # Clean expired nonces (older than 5 minutes)
    now = time.time()
    try:
        for f in os.listdir(NONCE_DIR):
            fp = os.path.join(NONCE_DIR, f)
            if f.endswith('.json') and os.path.isfile(fp):
                if now - os.path.getmtime(fp) > 300:
                    os.remove(fp)
    except OSError:
        pass


def log_entry(cmd, decision, exit_code=None):
    ts = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
    entry = {
        'timestamp': ts,
        'command': cmd,
        'decision': decision,
        'exit_code': exit_code,
    }
    try:
        with open(LOG_FILE, 'a') as f:
            f.write(json.dumps(entry) + '\n')
    except OSError:
        pass


# --- Nonce Functions ---

def generate_nonce():
    return os.urandom(4).hex()


def save_nonce(nonce, cmd):
    ts = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
    data = {'nonce': nonce, 'cmd': cmd, 'ts': ts}
    path = os.path.join(NONCE_DIR, f'{nonce}.json')
    with open(path, 'w') as f:
        json.dump(data, f)


def verify_nonce(nonce, current_cmd):
    path = os.path.join(NONCE_DIR, f'{nonce}.json')
    if not os.path.isfile(path):
        return False, 'invalid or expired nonce'
    # Check age (5 minute expiry)
    if time.time() - os.path.getmtime(path) > 300:
        os.remove(path)
        return False, 'nonce expired'
    with open(path) as f:
        data = json.load(f)
    if data['cmd'] != current_cmd:
        return False, 'command does not match dry-run'
    # Valid - delete (one-time use)
    os.remove(path)
    return True, None


# --- Database ---

def get_db():
    if not os.path.isfile(DB_PATH):
        print(json.dumps({'error': f'database not found: {DB_PATH}'}))
        sys.exit(1)
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute('PRAGMA foreign_keys = ON')
    return conn


def rows_to_list(rows):
    return [dict(row) for row in rows]


# --- Output ---

def output_json(data):
    print(json.dumps(data, indent=2))


def deny(reason, cmd_str):
    log_entry(cmd_str, 'BLOCKED')
    output_json({'error': f'BLOCKED: {reason}'})
    sys.exit(1)


# --- Command: companies ---

def cmd_companies_list(args, cmd_str):
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    rows = db.execute('SELECT * FROM companies ORDER BY name').fetchall()
    output_json(rows_to_list(rows))
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_companies_view(args, cmd_str):
    if args.id is None:
        deny('companies view requires an ID', cmd_str)
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    company = db.execute('SELECT * FROM companies WHERE id = ?', (args.id,)).fetchone()
    if not company:
        output_json({'error': f'company {args.id} not found'})
        log_entry(cmd_str, 'ALLOWED', 1)
        sys.exit(1)
    result = dict(company)
    result['contacts'] = rows_to_list(
        db.execute('SELECT * FROM contacts WHERE company_id = ?', (args.id,)).fetchall()
    )
    result['tickets'] = rows_to_list(
        db.execute('SELECT * FROM tickets WHERE company_id = ?', (args.id,)).fetchall()
    )
    result['files'] = rows_to_list(
        db.execute(
            'SELECT df.* FROM drive_files df '
            'JOIN company_files cf ON cf.file_id = df.id '
            'WHERE cf.company_id = ?',
            (args.id,),
        ).fetchall()
    )
    output_json(result)
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_companies_create(args, cmd_str):
    data = _parse_json_arg(args, cmd_str)
    if 'name' not in data or not data['name']:
        deny('companies create requires "name" in JSON', cmd_str)
    _write_gate(args, cmd_str, 'Create company', data)
    db = get_db()
    cols = []
    vals = []
    allowed = ('name', 'description', 'domains', 'health_score', 'account_tier',
               'industry', 'renewal_date', 'custom_fields', 'freshdesk_id')
    for k in allowed:
        if k in data:
            cols.append(k)
            v = data[k]
            if isinstance(v, (dict, list)):
                v = json.dumps(v)
            vals.append(v)
    placeholders = ', '.join('?' for _ in cols)
    col_str = ', '.join(cols)
    try:
        cursor = db.execute(f'INSERT INTO companies ({col_str}) VALUES ({placeholders})', vals)
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    row = db.execute('SELECT * FROM companies WHERE id = ?', (cursor.lastrowid,)).fetchone()
    output_json(dict(row))
    log_entry(cmd_str, 'CONFIRMED', 0)


def cmd_companies_update(args, cmd_str):
    if args.id is None:
        deny('companies update requires an ID', cmd_str)
    data = _parse_json_arg(args, cmd_str)
    if not data:
        deny('companies update requires at least one field in JSON', cmd_str)
    _write_gate(args, cmd_str, f'Update company {args.id}', data)
    db = get_db()
    existing = db.execute('SELECT id FROM companies WHERE id = ?', (args.id,)).fetchone()
    if not existing:
        output_json({'error': f'company {args.id} not found'})
        sys.exit(1)
    allowed = ('name', 'description', 'domains', 'health_score', 'account_tier',
               'industry', 'renewal_date', 'custom_fields', 'freshdesk_id')
    sets = []
    vals = []
    for k in allowed:
        if k in data:
            sets.append(f'{k} = ?')
            v = data[k]
            if isinstance(v, (dict, list)):
                v = json.dumps(v)
            vals.append(v)
    if not sets:
        deny('no valid fields to update', cmd_str)
    sets.append("updated_at = strftime('%Y-%m-%dT%H:%M:%SZ', 'now')")
    vals.append(args.id)
    try:
        db.execute(f'UPDATE companies SET {", ".join(sets)} WHERE id = ?', vals)
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    row = db.execute('SELECT * FROM companies WHERE id = ?', (args.id,)).fetchone()
    output_json(dict(row))
    log_entry(cmd_str, 'CONFIRMED', 0)


# --- Command: contacts ---

def cmd_contacts_list(args, cmd_str):
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    if args.company_id is not None:
        rows = db.execute(
            'SELECT co.*, c.name AS company_name '
            'FROM contacts co LEFT JOIN companies c ON co.company_id = c.id '
            'WHERE co.company_id = ? ORDER BY co.name',
            (args.company_id,),
        ).fetchall()
    else:
        rows = db.execute(
            'SELECT co.*, c.name AS company_name '
            'FROM contacts co LEFT JOIN companies c ON co.company_id = c.id '
            'ORDER BY co.name'
        ).fetchall()
    output_json(rows_to_list(rows))
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_contacts_view(args, cmd_str):
    if args.id is None:
        deny('contacts view requires an ID', cmd_str)
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    row = db.execute('SELECT * FROM contacts WHERE id = ?', (args.id,)).fetchone()
    if not row:
        output_json({'error': f'contact {args.id} not found'})
        log_entry(cmd_str, 'ALLOWED', 1)
        sys.exit(1)
    result = dict(row)
    result['tickets'] = rows_to_list(
        db.execute('SELECT * FROM tickets WHERE requester_id = ?', (args.id,)).fetchall()
    )
    output_json(result)
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_contacts_create(args, cmd_str):
    data = _parse_json_arg(args, cmd_str)
    if not data.get('name') and not (data.get('first_name') or data.get('last_name')):
        deny('contacts create requires "name" or "first_name"/"last_name" in JSON', cmd_str)
    _write_gate(args, cmd_str, 'Create contact', data)
    db = get_db()
    cols = []
    vals = []
    allowed = ('name', 'first_name', 'last_name', 'email', 'phone', 'mobile',
               'job_title', 'address', 'company_id', 'active', 'vip', 'tags',
               'other_emails', 'preferred_source', 'freshdesk_id')
    for k in allowed:
        if k in data:
            cols.append(k)
            v = data[k]
            if isinstance(v, (dict, list)):
                v = json.dumps(v)
            vals.append(v)
    placeholders = ', '.join('?' for _ in cols)
    col_str = ', '.join(cols)
    try:
        cursor = db.execute(f'INSERT INTO contacts ({col_str}) VALUES ({placeholders})', vals)
        db.commit()
    except sqlite3.IntegrityError as e:
        db.close()
        deny(f"Database integrity error: {e}", cmd_str)
    row = db.execute('SELECT * FROM contacts WHERE id = ?', (cursor.lastrowid,)).fetchone()
    output_json(dict(row))
    log_entry(cmd_str, 'CONFIRMED', 0)


