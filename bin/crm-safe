# --- Command: tickets ---

def cmd_tickets_list(args, cmd_str):
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    query = (
        'SELECT t.*, ts.name AS status_name, co.name AS requester_name, c.name AS company_name '
        'FROM tickets t '
        'LEFT JOIN ticket_statuses ts ON t.status = ts.status_id '
        'LEFT JOIN contacts co ON t.requester_id = co.id '
        'LEFT JOIN companies c ON t.company_id = c.id'
    )
    params = []
    conditions = []
    if args.company_id is not None:
        conditions.append('t.company_id = ?')
        params.append(args.company_id)
    if args.status is not None:
        conditions.append('t.status = ?')
        params.append(args.status)
    if conditions:
        query += ' WHERE ' + ' AND '.join(conditions)
    query += ' ORDER BY t.created_at DESC'
    rows = db.execute(query, params).fetchall()
    output_json(rows_to_list(rows))
    log_entry(cmd_str, 'ALLOWED', 0)


def cmd_tickets_view(args, cmd_str):
    if args.id is None:
        deny('tickets view requires an ID', cmd_str)
    log_entry(cmd_str, 'ALLOWED')
    db = get_db()
    row = db.execute('SELECT * FROM tickets WHERE id = ?', (args.id,)).fetchone()
    if not row:
        output_json({'error': f'ticket {args.id} not found'})
        log_entry(cmd_str, 'ALLOWED', 1)
        sys.exit(1)
    output_json(dict(row))
    log_entry(cmd_str, 'ALLOWED', 0)


